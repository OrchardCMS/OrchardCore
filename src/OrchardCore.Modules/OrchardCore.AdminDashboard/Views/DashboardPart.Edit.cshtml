@using OrchardCore
@model DashboardPartViewModel

<div class="ocat-wrapper" asp-validation-class-for="Position">
    <label asp-for="Position" class="ocat-label">@T["Position"] </label>
    <div class="ocat-end">
        <input asp-for="Position" class="form-control" />
        <span asp-validation-for="Position"></span>
    </div>
</div>

<div class="ocat-wrapper" asp-validation-class-for="Width">
    <label asp-for="Width" class="ocat-label">@T["Width"] </label>
    <div class="ocat-end">
        <input asp-for="Width" class="form-control" />
        <span asp-validation-for="Width"></span>
    </div>
</div>

<div class="ocat-wrapper" asp-validation-class-for="Height">
    <label asp-for="Height" class="ocat-label">@T["Height"] </label>
    <div class="ocat-end">
        <input asp-for="Height" class="form-control" />
        <span asp-validation-for="Height"></span>
    </div>
</div>
