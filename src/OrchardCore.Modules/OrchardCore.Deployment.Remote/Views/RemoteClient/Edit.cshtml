@model EditRemoteClientViewModel

<zone Name="Title"><h1>@RenderTitleSegments(T["Edit Remote Client"])</h1></zone>

<div asp-validation-summary="ModelOnly"></div>
<form asp-action="Edit" method="post" class="no-multisubmit">
    <input type="hidden" asp-for="Id" />

    <div class="@Orchard.GetWrapperClasses()" asp-validation-class-for="ClientName">
        <label asp-for="ClientName" class="@Orchard.GetLabelClasses()">@T["Client Name"]</label>
        <div class="@Orchard.GetEndClasses()">
        <input asp-for="ClientName" class="form-control" />
        <span asp-validation-for="ClientName" class="text-danger"></span>
        </div>
    </div>

    <div class="@Orchard.GetWrapperClasses()" asp-validation-class-for="ApiKey">
        <label asp-for="ApiKey" class="@Orchard.GetLabelClasses()">@T["Api Key"]</label>
        <div class="@Orchard.GetEndClasses()">
        <input asp-for="ApiKey" type="password" class="form-control" value="@Model.ApiKey" />
        <span asp-validation-for="ApiKey" class="text-danger"></span>
        </div>
    </div>

    <div class="@Orchard.GetWrapperClasses()">
        <div class="@Orchard.GetEndClasses(true)">
            <button class="btn btn-primary save" type="submit">@T["Save"]</button>
            <a class="btn btn-secondary cancel" role="button" asp-route-action="Index">@T["Cancel"]</a>
        </div>
    </div>
</form>
