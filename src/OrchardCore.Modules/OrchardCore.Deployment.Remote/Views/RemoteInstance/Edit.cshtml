@model EditRemoteInstanceViewModel

<zone Name="Title"><h1>@RenderTitleSegments(T["Edit Remote Instance"])</h1></zone>

<div asp-validation-summary="ModelOnly"></div>
<form asp-action="Edit" method="post" class="no-multisubmit">
    <input type="hidden" asp-for="Id" />

    <div class="ocat-wrapper" asp-validation-class-for="Name">
        <label asp-for="Name" class="ocat-label">@T["Name"]</label>
        <div class="ocat-end">
        <input asp-for="Name" class="form-control" autofocus />
        <span asp-validation-for="Name" class="text-danger"></span>
        </div>
    </div>

    <div class="ocat-wrapper" asp-validation-class-for="Url">
        <label asp-for="Url" class="ocat-label">@T["Url"]</label>
        <div class="ocat-end">
        <input asp-for="Url" class="form-control" />
        <span asp-validation-for="Url" class="text-danger"></span>
        </div>
    </div>

    <div class="ocat-wrapper" asp-validation-class-for="ClientName">
        <label asp-for="ClientName" class="ocat-label">@T["Client Name"]</label>
        <div class="ocat-end">
        <input asp-for="ClientName" class="form-control" />
        <span asp-validation-for="ClientName" class="text-danger"></span>
        </div>
    </div>

    <div class="ocat-wrapper" asp-validation-class-for="ApiKey">
        <label asp-for="ApiKey" class="ocat-label">@T["Api Key"]</label>
        <div class="ocat-end">
        <input asp-for="ApiKey" class="form-control" type="password" value="@Model.ApiKey" />
        <span asp-validation-for="ApiKey" class="text-danger"></span>
        </div>
    </div>

    <div class="ocat-wrapper">
        <div class="ocat-end-offset">
            <button class="btn btn-primary save" type="submit">@T["Save"]</button>
            <a class="btn btn-secondary cancel" role="button" asp-route-action="Index">@T["Cancel"]</a>
        </div>
    </div>
</form>
