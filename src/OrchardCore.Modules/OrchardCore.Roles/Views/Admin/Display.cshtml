@model DisplayRoleViewModel
@using OrchardCore.Roles.ViewModels

<zone Name="Title">
    <h1>
        @RenderTitleSegments(Model.Role.RoleName)
    </h1>
</zone>

<div class="mb-3 text-muted">@Model.Role.RoleDescription</div>

@await Html.PartialAsync("_RolePermissions", Model.Permissions)

<form>
    <div class="ocat-wrapper">
        <div class="ocat-end-offset">
            <a class="btn btn-secondary" role="button" asp-route-action="Index">@T["Back"]</a>
        </div>
    </div>
</form>
