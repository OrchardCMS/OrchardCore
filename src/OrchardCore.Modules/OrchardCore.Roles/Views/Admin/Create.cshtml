@model CreateRoleViewModel
@using OrchardCore.Roles.ViewModels

<zone Name="Title"><h1>@RenderTitleSegments(T["Create Role"])</h1></zone>

<div asp-validation-summary="ModelOnly"></div>

<form asp-action="Create" method="post" class="no-multisubmit">
    <div class="@Orchard.GetWrapperClasses()" asp-validation-class-for="RoleName">
        <label asp-for="RoleName" class="@Orchard.GetLabelClasses()">@T["Name"]</label>
        <div class="@Orchard.GetEndClasses()">
        <input asp-for="RoleName" class="form-control" autofocus />
        <span asp-validation-for="RoleName" class="text-danger"></span>
        </div>
    </div>

    <div class="@Orchard.GetWrapperClasses()" asp-validation-class-for="RoleDescription">
        <label asp-for="RoleDescription" class="@Orchard.GetLabelClasses()">@T["Description"]</label>
        <div class="@Orchard.GetEndClasses()">
        <textarea asp-for="RoleDescription" class="form-control"></textarea>
        <span asp-validation-for="RoleDescription" class="text-danger"></span>
        </div>
    </div>

    <div class="@Orchard.GetWrapperClasses()">
        <div class="@Orchard.GetEndClasses(true)">
            <button class="btn btn-primary create" type="submit">@T["Create"]</button>
            <a class="btn btn-secondary cancel" role="button" asp-route-action="Index">@T["Cancel"]</a>
        </div>
    </div>
</form>
