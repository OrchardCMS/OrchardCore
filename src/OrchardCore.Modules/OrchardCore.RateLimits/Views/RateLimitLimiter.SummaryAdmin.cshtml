@model dynamic

<div class="w-100">
    @if (Model.Actions != null && (Model.CanManage as bool? ?? false))
    {
        <div class="float-end">
            @await DisplayAsync(Model.Actions)
        </div>
    }

    @if (Model.Content != null)
    {
        @await DisplayAsync(Model.Content)
    }
</div>
