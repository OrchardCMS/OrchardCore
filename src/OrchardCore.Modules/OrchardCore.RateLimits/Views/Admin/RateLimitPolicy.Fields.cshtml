@using OrchardCore.RateLimits.Models
@model OrchardCore.RateLimits.ViewModels.RateLimitPolicyEditViewModel

<div class="ocat-wrapper" asp-validation-class-for="Name">
    <label asp-for="Name" class="ocat-label ocat-label-required">@T["Policy name"]</label>
    <div class="ocat-end">
        <input asp-for="Name" class="form-control" autofocus="autofocus" />
        <span asp-validation-for="Name"></span>
        <span class="hint">@T["Use a unique name to identify this tenant policy."]</span>
    </div>
</div>

<div class="ocat-wrapper" asp-validation-class-for="Description">
    <label asp-for="Description" class="ocat-label">@T["Description"]</label>
    <div class="ocat-end">
        <textarea asp-for="Description" class="form-control" rows="3"></textarea>
        <span asp-validation-for="Description"></span>
        <span class="hint">@T["Optionally describe what this policy is intended to protect."]</span>
    </div>
</div>

<div class="ocat-wrapper" asp-validation-class-for="Scope">
    <label asp-for="Scope" class="ocat-label">@T["Policy type"]</label>
    <div class="ocat-end">
        <select asp-for="Scope" asp-items="Model.PolicyScopes" class="form-select"></select>
        <span asp-validation-for="Scope"></span>
        <span class="hint">@T["Global applies everywhere, and Endpoint matches a request path prefix."]</span>
    </div>
</div>

<div id="@(Html.IdFor(m => m.Path))_group" class="ocat-wrapper @(Model.Scope == RateLimitPolicyScope.Endpoint ? string.Empty : "d-none")" asp-validation-class-for="Path">
    <label asp-for="Path" class="ocat-label">@T["Request path"]</label>
    <div class="ocat-end">
        <input asp-for="Path" class="form-control" />
        <span asp-validation-for="Path"></span>
        <span class="hint">@T["Matches requests that start with this path, for example '/api/' or '/users/login'."]</span>
    </div>
</div>

<script at="Foot">
    document.addEventListener('DOMContentLoaded', () => {
        const scopeElement = document.getElementById('@Html.IdFor(m => m.Scope)');
        const pathGroup = document.getElementById('@($"{Html.IdFor(m => m.Path)}_group")');

        if (!scopeElement || !pathGroup) {
            return;
        }

        const updateScopeFields = () => {
            const scope = scopeElement.value;
            pathGroup.classList.toggle('d-none', scope !== '@RateLimitPolicyScope.Endpoint');
        };

        scopeElement.addEventListener('change', updateScopeFields);
        updateScopeFields();
    });
</script>
