@using OrchardCore.RateLimits.Models
@model OrchardCore.RateLimits.ViewModels.RateLimitPolicyEditViewModel

@{
    var isTargetLocked = Model.InitialIsEnabled;
}

<div class="rate-limit-policy-fields" data-is-target-locked="@isTargetLocked.ToString().ToLowerInvariant()" data-endpoint-scope="@RateLimitPolicyScope.Endpoint" data-group-scope="@RateLimitPolicyScope.Group">

<div class="ocat-wrapper" asp-validation-class-for="Name">
    <label asp-for="Name" class="ocat-label ocat-label-required">@T["Policy name"]</label>
    <div class="ocat-end">
        <input asp-for="Name" class="form-control" autofocus="autofocus" />
        <span asp-validation-for="Name"></span>
        <span class="hint">@T["Use a unique name to identify this tenant policy."]</span>
    </div>
</div>

<div class="ocat-wrapper" asp-validation-class-for="Description">
    <label asp-for="Description" class="ocat-label">@T["Description"]</label>
    <div class="ocat-end">
        <textarea asp-for="Description" class="form-control" rows="3"></textarea>
        <span asp-validation-for="Description"></span>
        <span class="hint">@T["Optionally describe what this policy is intended to protect."]</span>
    </div>
</div>

<input asp-for="IsEnabled" type="hidden" />

<div class="ocat-wrapper" asp-validation-class-for="Scope">
    <label asp-for="Scope" class="ocat-label">@T["Policy type"]</label>
    <div class="ocat-end">
        @if (isTargetLocked)
        {
            <input asp-for="Scope" type="hidden" />
        }
        <select asp-for="Scope" asp-items="Model.PolicyScopes" class="form-select" disabled="@isTargetLocked"></select>
        <span asp-validation-for="Scope"></span>
        <span class="hint">
            @if (isTargetLocked)
            {
                @T["The policy type is read-only while this policy is enabled. Disable it first to retarget the policy."]
            }
            else
            {
                @T["Global applies everywhere, Endpoint matches a request path prefix, and Group matches endpoints assigned to a named rate-limit group."]
            }
        </span>
    </div>
</div>

<div id="Path_group" class="ocat-wrapper @(Model.Scope == RateLimitPolicyScope.Endpoint ? string.Empty : "d-none")" asp-validation-class-for="Path">
    <label asp-for="Path" class="ocat-label">@T["Request path"]</label>
    <div class="ocat-end">
        @if (isTargetLocked)
        {
            <input asp-for="Path" type="hidden" />
        }
        <input asp-for="Path" class="form-control" readonly="@isTargetLocked" />
        <span asp-validation-for="Path"></span>
        <span class="hint">
            @if (isTargetLocked)
            {
                @T["The request path is read-only while this policy is enabled. Disable it first to change endpoint targeting."]
            }
            else
            {
                @T["Matches requests that start with this path, for example '/api/' or '/users/login'."]
            }
        </span>
    </div>
</div>

<div id="GroupName_group" class="ocat-wrapper @(Model.Scope == RateLimitPolicyScope.Group ? string.Empty : "d-none")" asp-validation-class-for="GroupName">
    <label asp-for="GroupName" class="ocat-label">@T["Rate-limit group"]</label>
    <div class="ocat-end">
        @if (isTargetLocked)
        {
            <input asp-for="GroupName" type="hidden" />
        }
        <select asp-for="GroupName" asp-items="Model.AvailableGroups" class="form-select" disabled="@isTargetLocked"></select>
        <span asp-validation-for="GroupName"></span>
        <span class="hint">
            @if (isTargetLocked)
            {
                @T["The group target is read-only while this policy is enabled. Disable it first to choose a different group."]
            }
            else
            {
                @T["Choose a group declared on one or more endpoints with the RateLimitGroup attribute or WithRateLimitGroups()."]
            }
        </span>
    </div>
</div>

</div>

<script asp-src="~/OrchardCore.RateLimits/Scripts/rate-limit-policy-fields/rate-limit-policy-fields.min.js" debug-src="~/OrchardCore.RateLimits/Scripts/rate-limit-policy-fields/rate-limit-policy-fields.js" at="Foot" type="module"></script>
