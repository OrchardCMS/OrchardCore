@using OrchardCore.RateLimits.Models
@model OrchardCore.RateLimits.ViewModels.RateLimitPolicyEditViewModel

<zone Name="Title"><h1>@RenderTitleSegments(T["Edit Rate Limit Policy"])</h1></zone>

<form asp-action="Edit" asp-route-policyId="@Model.PolicyId" method="post" class="no-multisubmit">
    @Html.ValidationSummary()

    @await Html.PartialAsync("RateLimitPolicy.Fields", Model)

    <div class="ocat-wrapper">
        <div class="ocat-end-offset">
            <div class="alert alert-warning mb-0" role="alert">
                @T["Publishing a policy will restart the website."]
            </div>
        </div>
    </div>

    <div class="card mt-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="mb-0">@(Model.Status == OrchardCore.RateLimits.Models.RateLimitPolicyStatus.PublishedWithDraft ? T["Draft limiters"] : T["Limiters"])</h5>
            <button type="button" class="btn btn-secondary btn-sm" data-bs-toggle="modal" data-bs-target="#modalAddLimiter">@T["Add Limiter"]</button>
        </div>
        <div class="card-body">
            @if (Model.DraftLimiters.Count == 0)
            {
                <div class="alert alert-info mb-0" role="alert">@T["Add one or more limiters before publishing this policy."]</div>
            }
            else
            {
                <ul class="list-group">
                    @foreach (var limiter in Model.DraftLimiters)
                    {
                        <li class="list-group-item">@await DisplayAsync(limiter.Shape)</li>
                    }
                </ul>
            }
        </div>
    </div>

    @if (Model.Status == RateLimitPolicyStatus.PublishedWithDraft && Model.PublishedLimiters.Count > 0)
    {
        <div class="accordion mt-4" id="published-version-accordion">
            <div class="accordion-item">
                <h2 class="accordion-header" id="published-version-heading">
                    <button class="accordion-button collapsed"
                            type="button"
                            data-bs-toggle="collapse"
                            data-bs-target="#published-version"
                            aria-expanded="false"
                            aria-controls="published-version">
                        @T["Published version"]
                    </button>
                </h2>
                <div id="published-version" class="accordion-collapse collapse" aria-labelledby="published-version-heading" data-bs-parent="#published-version-accordion">
                    <div class="accordion-body">
                        <p class="text-muted">@Model.PublishedTargetDescription</p>
                        <ul class="list-group">
                            @foreach (var limiter in Model.PublishedLimiters)
                            {
                                <li class="list-group-item">@await DisplayAsync(limiter.Shape)</li>
                            }
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    }

    <div class="ocat-wrapper mt-4">
        <div class="ocat-end-offset">
            <p class="mb-3">
                @if (Model.Status == OrchardCore.RateLimits.Models.RateLimitPolicyStatus.Draft)
                {
                    @T["This policy only exists as a draft. Publish it to start enforcing it."]
                }
                else if (Model.Status == OrchardCore.RateLimits.Models.RateLimitPolicyStatus.Published)
                {
                    @T["This policy is currently published. Save a draft to make changes without restarting the website."]
                }
                else
                {
                    @T["The draft differs from the published version. Publish to apply the pending changes."]
                }
            </p>
            <div class="d-flex gap-1 flex-wrap">
                <button class="btn btn-primary" type="submit" name="submit.Save" value="submit.Save">@T["Save Draft"]</button>
                <button class="btn btn-success" type="submit" name="submit.Publish" value="submit.Publish">@T["Save & Publish"]</button>
                <a asp-action="Index" class="btn btn-secondary">@T["Cancel"]</a>
            </div>
        </div>
    </div>
</form>

<div class="modal fade" id="modalAddLimiter" tabindex="-1" role="dialog" aria-labelledby="available-limiter-types-title" aria-hidden="true">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="available-limiter-types-title">@T["Available Limiter Types"]</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="row row-cols-1 row-cols-md-2 g-3">
                    @foreach (var source in Model.LimiterSources)
                    {
                        OrchardCore.DisplayManagement.IShape shape = await New.RateLimitLimiter_Link(Source: source, PolicyId: Model.PolicyId);
                        @await DisplayAsync(shape)
                    }
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">@T["Cancel"]</button>
            </div>
        </div>
    </div>
</div>
