@model OrchardCore.RateLimits.ViewModels.RateLimitPolicyEditViewModel

<zone Name="Title"><h1>@RenderTitleSegments(T["Edit Rate Limit Policy"])</h1></zone>

@{
    var limiterActionsDisabled = !Model.AreLimiterChangesAllowed;
}

<form asp-action="Edit" asp-route-policyId="@Model.PolicyId" method="post" class="no-multisubmit">
    @Html.ValidationSummary()

    @await Html.PartialAsync("RateLimitPolicy.Fields", Model)

    @if (limiterActionsDisabled)
    {
        <div class="ocat-wrapper">
            <div class="ocat-end-offset">
                <div class="alert alert-warning mb-0" role="alert">
                    @Model.PublishedPolicyLimiterMessage
                </div>
            </div>
        </div>
    }

    <div class="card mt-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="mb-0">@T["Limiters"]</h5>
            <button type="button"
                    class="btn btn-secondary btn-sm"
                    data-bs-toggle="modal"
                    data-bs-target="#modalAddLimiter"
                    disabled="@limiterActionsDisabled"
                    title="@(limiterActionsDisabled ? Model.PublishedPolicyLimiterMessage : null)">@T["Add Limiter"]</button>
        </div>
        <div class="card-body">
            @if (Model.Limiters.Count == 0)
            {
                <div class="alert alert-info mb-0" role="alert">@T["Add one or more limiters before enabling this policy."]</div>
            }
            else
            {
                <ul class="list-group">
                    @foreach (var limiter in Model.Limiters)
                    {
                        <li class="list-group-item">@await DisplayAsync(limiter.Shape)</li>
                    }
                </ul>
            }
        </div>
    </div>

    <div class="ocat-wrapper mt-4">
        <div class="ocat-end-offset">
            @if (!Model.IsEnabled)
            {
                <p class="mb-3">@T["This policy is disabled. You can save changes without restarting the website. Enable it from the policies list when it is ready to publish."]</p>
            }
            <div class="d-flex gap-1 flex-wrap">
                <button class="btn btn-primary" type="submit">@T["Save"]</button>
                <a asp-action="Index" class="btn btn-secondary">@T["Cancel"]</a>
            </div>
        </div>
    </div>
</form>

<div class="modal fade" id="modalAddLimiter" tabindex="-1" role="dialog" aria-labelledby="available-limiter-types-title" aria-hidden="true">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="available-limiter-types-title">@T["Available Limiter Types"]</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body">
                <div class="row row-cols-1 row-cols-md-2 g-3">
                    @foreach (var source in Model.LimiterSources)
                    {
                        OrchardCore.DisplayManagement.IShape shape = await New.RateLimitLimiter_Link(Source: source, PolicyId: Model.PolicyId, AreLimiterChangesAllowed: Model.AreLimiterChangesAllowed, PublishedPolicyLimiterMessage: Model.PublishedPolicyLimiterMessage);
                        @await DisplayAsync(shape)
                    }
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">@T["Cancel"]</button>
            </div>
        </div>
    </div>
</div>
