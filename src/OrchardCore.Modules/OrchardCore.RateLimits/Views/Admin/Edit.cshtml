@model OrchardCore.RateLimits.ViewModels.RateLimitPolicyEditViewModel

<zone Name="Title"><h1>@RenderTitleSegments(T["Edit Rate Limit Policy"])</h1></zone>

<form asp-action="Edit" asp-route-policyId="@Model.PolicyId" method="post" class="no-multisubmit">
    @Html.ValidationSummary()

    @await Html.PartialAsync("RateLimitPolicy.Fields", Model)

    <div class="ocat-wrapper">
        <div class="ocat-end-offset">
            <div class="alert alert-warning mb-0" role="alert">
                @T["Saving changes to an enabled policy, or changing its enabled state, will restart the website."]
            </div>
        </div>
    </div>

    <div class="card mt-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="mb-0">@T["Limiters"]</h5>
            <button type="button" class="btn btn-secondary btn-sm" data-bs-toggle="modal" data-bs-target="#modalAddLimiter">@T["Add Limiter"]</button>
        </div>
        <div class="card-body">
            @if (Model.Limiters.Count == 0)
            {
                <div class="alert alert-info mb-0" role="alert">@T["Add one or more limiters before enabling this policy."]</div>
            }
            else
            {
                <ul class="list-group">
                    @foreach (var limiter in Model.Limiters)
                    {
                        <li class="list-group-item">@await DisplayAsync(limiter.Shape)</li>
                    }
                </ul>
            }
        </div>
    </div>

    <div class="ocat-wrapper mt-4">
        <div class="ocat-end-offset">
            <p class="mb-3">
                @if (Model.IsEnabled)
                {
                    @T["This policy is enabled. Saving changes will restart the website so the updated policy is reloaded."]
                }
                else if (Model.InitialIsEnabled)
                {
                    @T["This policy is currently enabled. Disabling and saving it will restart the website so it stops being enforced."]
                }
                else
                {
                    @T["This policy is disabled. You can save changes without restarting the website until you enable it."]
                }
            </p>
            <div class="d-flex gap-1 flex-wrap">
                <button class="btn btn-primary" type="submit" data-confirm-save="true">@T["Save"]</button>
                <a asp-action="Index" class="btn btn-secondary">@T["Cancel"]</a>
            </div>
        </div>
    </div>
</form>

<div class="modal fade" id="modalAddLimiter" tabindex="-1" role="dialog" aria-labelledby="available-limiter-types-title" aria-hidden="true">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="available-limiter-types-title">@T["Available Limiter Types"]</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <script at="Foot">
                document.addEventListener('DOMContentLoaded', () => {
                    const enabledInput = document.getElementById('@Html.IdFor(m => m.IsEnabled)');
                    const initialIsEnabled = @Model.InitialIsEnabled.ToString().ToLowerInvariant();

                    for (const button of document.querySelectorAll('[data-confirm-save]')) {
                        button.addEventListener('click', (event) => {
                            if (!enabledInput) {
                                return;
                            }

                            const shouldRestart = initialIsEnabled || enabledInput.checked;
                            if (!shouldRestart) {
                                return;
                            }

                            event.preventDefault();
                            confirmDialog({
                                title: '@T["Save Policy"]',
                                message: '@T["Are you sure you want to save this policy? This website will restart after saving because the active rate-limit configuration will change."]',
                                callback: (confirmed) => {
                                    if (!confirmed) {
                                        return;
                                    }

                                    button.form?.requestSubmit(button);
                                }
                            });
                        });
                    }
                });
            </script>
            <div class="modal-body">
                <div class="row row-cols-1 row-cols-md-2 g-3">
                    @foreach (var source in Model.LimiterSources)
                    {
                        OrchardCore.DisplayManagement.IShape shape = await New.RateLimitLimiter_Link(Source: source, PolicyId: Model.PolicyId);
                        @await DisplayAsync(shape)
                    }
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">@T["Cancel"]</button>
            </div>
        </div>
    </div>
</div>
