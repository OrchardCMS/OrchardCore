@using System.Globalization
@model OrchardCore.RateLimits.ViewModels.RateLimitsIndexViewModel

<zone Name="Title"><h1>@RenderTitleSegments(T["Rate Limit Policies"])</h1></zone>

<form asp-action="Index" method="get" class="mb-3">
    <div class="card text-bg-theme position-sticky action-bar">
        <div class="card-body">
            <div class="row g-3 align-items-end">
                <div class="col">
                    <label for="search-text" class="visually-hidden">@T["Search policies"]</label>
                    <input id="search-text" name="searchText" value="@Model.SearchText" class="form-control" placeholder="@T["Search policies"]" />
                </div>
                <div class="col-auto d-flex gap-1">
                    <button class="btn btn-secondary" type="submit">@T["Search"]</button>
                    @if (!string.IsNullOrWhiteSpace(Model.SearchText))
                    {
                        <a asp-action="Index" class="btn btn-outline-secondary">@T["Clear"]</a>
                    }
                    <a asp-action="Create" class="btn btn-primary">@T["Add Policy"]</a>
                </div>
            </div>
        </div>
    </div>
</form>

<form asp-action="Index" method="post" class="no-multisubmit">
    <input asp-for="@(new OrchardCore.RateLimits.ViewModels.RateLimitsBulkActionViewModel().BulkAction)" type="hidden" name="BulkAction" />
    <input type="submit" name="submit.BulkAction" class="visually-hidden" />

    <ul class="list-group with-checkbox">
        @if (Model.Policies.Count > 0)
        {
            <li class="list-group-item text-bg-theme">
                <div class="row gx-3">
                    <div class="col">
                        <div class="form-check my-1">
                            <input type="checkbox" class="form-check-input" id="select-all">
                            <label class="form-check-label" for="select-all" id="select-all-label" title="@T["Select All"]"></label>
                            <label id="items" for="select-all">@T.Plural(Model.Policies.Count, "{0} policy", "{0} policies")</label>
                            <label id="selected-items" class="text-muted d-none" for="select-all"></label>
                        </div>
                    </div>
                    <div class="col-auto">
                        <div class="dropdown d-none" id="actions">
                            <button class="btn btn-sm btn-light dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                @T["Actions"]
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end">
                                @foreach (var item in Model.BulkActions)
                                {
                                    <li><a class="dropdown-item" href="javascript:void(0)" data-action="@item.Value" data-title="@T["Bulk Action"]" data-message="@T["Are you sure you want to {0} the selected policies?", item.Text.ToLowerInvariant()]">@item.Text</a></li>
                                }
                            </ul>
                        </div>
                    </div>
                </div>
            </li>

            @foreach (var entry in Model.Policies)
            {
                var publishedUtc = entry.PublishedUtc?.ToString("yyyy-MM-ddTHH:mm:sszzz", CultureInfo.InvariantCulture);
                <li class="list-group-item">
                    <div class="d-flex gap-3">
                        <div class="form-check mt-1">
                            <input type="checkbox" class="form-check-input" value="@entry.PolicyId" name="policyIds" id="policy-@entry.PolicyId">
                            <label class="form-check-label" for="policy-@entry.PolicyId">&nbsp;</label>
                        </div>
                        <div class="flex-grow-1">
                            <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap">
                                <div>
                                    <div class="summary d-flex flex-column flex-md-row">
                                        <div class="me-2">
                                            <h5 class="mb-0">@entry.Name</h5>
                                        </div>
                                        <div class="tags me-1">
                                            <span class="badge ta-badge text-bg-@(entry.Status == OrchardCore.RateLimits.Models.RateLimitPolicyStatus.Draft ? "warning" : entry.Status == OrchardCore.RateLimits.Models.RateLimitPolicyStatus.Published ? "success" : "info")">
                                                @(entry.Status == OrchardCore.RateLimits.Models.RateLimitPolicyStatus.Draft ? T["Draft"] : entry.Status == OrchardCore.RateLimits.Models.RateLimitPolicyStatus.Published ? T["Published"] : T["Published + Draft"])
                                            </span>
                                        </div>
                                        @if (entry.PublishedUtc is not null)
                                        {
                                            <div class="metadata me-1">
                                                <span class="badge ta-badge font-weight-normal" data-bs-toggle="tooltip" title="@await DisplayAsync(await New.DateTime(Utc: entry.PublishedUtc, Format: "g"))">
                                                    <i class="fa-solid fa-calendar text-secondary" aria-hidden="true"></i> <time datetime="@publishedUtc">@await DisplayAsync(await New.Timespan(Utc: entry.PublishedUtc))</time>
                                                </span>
                                            </div>
                                        }
                                        @if (entry.Policy is not null)
                                        {
                                            var authorShape = await New.RateLimitPolicy_DefaultMeta_SummaryAdmin(Value: entry.Policy);
                                            authorShape.Metadata.DisplayType = "SummaryAdmin";
                                            <div class="metadata me-1">@await DisplayAsync(authorShape)</div>
                                        }
                                    </div>
                                    <div class="metadata mt-1 text-muted">@entry.TargetDescription</div>
                                    @if (!string.IsNullOrWhiteSpace(entry.Description))
                                    {
                                        <div class="metadata mt-1 text-muted">@entry.Description</div>
                                    }
                                </div>
                                <div class="d-flex gap-1">
                                    <a asp-action="Edit" asp-route-policyId="@entry.PolicyId" class="btn btn-primary btn-sm">@T["Edit"]</a>
                                    @if (entry.HasDraft)
                                    {
                                        <button type="button" class="btn btn-success btn-sm" data-publish-policy-id="@entry.PolicyId">@T["Publish"]</button>
                                    }
                                    <button type="button"
                                            class="btn btn-danger btn-sm"
                                            data-delete-policy-id="@entry.PolicyId"
                                            data-title="@T["Delete Policy"]"
                                            data-message="@T["Are you sure you want to delete this policy? This website will restart after deleting the policy."]">@T["Delete"]</button>
                                </div>
                            </div>
                        </div>
                    </div>
                </li>
            }
        }
        else
        {
            <li class="list-group-item">
                <div class="alert alert-info mb-0" role="alert">
                    @if (!string.IsNullOrWhiteSpace(Model.SearchText))
                    {
                        @T["<strong>Nothing here!</strong> No policies match the current search."]
                    }
                    else
                    {
                        @T["<strong>Nothing here!</strong> There are no rate limit policies yet."]
                    }
                </div>
            </li>
        }
    </ul>
</form>

<form asp-action="Delete" method="post" id="delete-policy-form" class="d-none">
    <input type="hidden" name="policyId" id="delete-policy-id" />
</form>

<form asp-action="Publish" method="post" id="publish-policy-form" class="d-none">
    <input type="hidden" name="policyId" id="publish-policy-id" />
</form>

<div class="card mt-4">
    <div class="card-header">
        <h5 class="mb-0">@T["Read-only Policies"]</h5>
    </div>
    <div class="card-body">
        @if (Model.BuiltInRouteLimits.Count == 0)
        {
            <p class="mb-0 text-muted">@T["No read-only policies are currently registered by enabled features."]</p>
        }
        else
        {
            <p class="text-muted">@T["These policies are set by features and are read-only."]</p>
            <ul class="list-group list-group-flush">
                @foreach (var route in Model.BuiltInRouteLimits)
                {
                    <li class="list-group-item px-0">
                        <div class="summary d-flex flex-column flex-md-row align-items-md-center gap-1">
                            <div class="me-2">
                                <strong>@route.Path</strong>
                            </div>
                            <div class="tags d-flex gap-1 flex-wrap">
                                @foreach (var method in route.Methods)
                                {
                                    <span class="badge ta-badge bg-primary-subtle text-primary-emphasis">@method</span>
                                }
                                <span class="badge ta-badge bg-secondary-subtle text-secondary-emphasis"
                                      data-bs-toggle="tooltip"
                                      title="@T["Route name: {0}", route.RouteName]">@T["Route"]</span>
                            </div>
                        </div>
                    </li>
                }
            </ul>
        }
    </div>
</div>

<script at="Foot">
    document.addEventListener('DOMContentLoaded', () => {
        const actions = document.getElementById('actions');
        const selectAll = document.getElementById('select-all');
        const items = document.getElementById('items');
        const selectedItems = document.getElementById('selected-items');
        const hiddenBulkAction = document.querySelector('[name="BulkAction"]');
        const submit = document.querySelector('[name="submit.BulkAction"]');
        const deletePolicyForm = document.getElementById('delete-policy-form');
        const deletePolicyId = document.getElementById('delete-policy-id');
        const publishPolicyForm = document.getElementById('publish-policy-form');
        const publishPolicyId = document.getElementById('publish-policy-id');

        const getCheckboxes = () => [...document.querySelectorAll('input[name="policyIds"]')];
        const updateSelection = () => {
            const checkboxes = getCheckboxes();
            const selectedCount = checkboxes.filter(x => x.checked).length;
            const totalCount = checkboxes.length;

            if (selectAll) {
                selectAll.checked = totalCount > 0 && selectedCount === totalCount;
                selectAll.indeterminate = selectedCount > 0 && selectedCount < totalCount;
            }

            if (actions) {
                actions.classList.toggle('d-none', selectedCount === 0);
            }

            if (items && selectedItems) {
                items.classList.toggle('d-none', selectedCount > 0);
                selectedItems.classList.toggle('d-none', selectedCount === 0);
                selectedItems.textContent = `${selectedCount} @T["selected"]`;
            }
        };

        selectAll?.addEventListener('change', () => {
            for (const checkbox of getCheckboxes()) {
                checkbox.checked = selectAll.checked;
            }

            updateSelection();
        });

        for (const checkbox of getCheckboxes()) {
            checkbox.addEventListener('change', updateSelection);
        }

        for (const action of document.querySelectorAll('.dropdown-item[data-action]')) {
            action.addEventListener('click', () => {
                confirmDialog({
                    ...action.dataset,
                    callback: (confirmed) => {
                        if (!confirmed) {
                            return;
                        }

                        hiddenBulkAction.value = action.dataset.action;
                        submit.click();
                    }
                });
            });
        }

        for (const button of document.querySelectorAll('[data-delete-policy-id]')) {
            button.addEventListener('click', () => {
                confirmDialog({
                    ...button.dataset,
                    callback: (confirmed) => {
                        if (!confirmed) {
                            return;
                        }

                        deletePolicyId.value = button.dataset.deletePolicyId;
                        deletePolicyForm.submit();
                    }
                });
            });
        }

        for (const button of document.querySelectorAll('[data-publish-policy-id]')) {
            button.addEventListener('click', () => {
                publishPolicyId.value = button.dataset.publishPolicyId;
                publishPolicyForm.submit();
            });
        }
    });
</script>
