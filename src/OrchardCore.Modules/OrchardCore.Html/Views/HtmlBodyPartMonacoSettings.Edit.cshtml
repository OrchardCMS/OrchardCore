@using OrchardCore.Mvc.Core.Utilities
@model OrchardCore.Html.ViewModels.MonacoSettingsViewModel

@{
    // Use Url.ToAbsoluteUrl() because Url.Content() leads to a js error: 'Not allowed to load local resource'.
    var IStandaloneEditorConstructionOptionsSchemaPath = Url.ToAbsoluteUrl("~/OrchardCore.Resources/Scripts/monaco/IStandaloneEditorConstructionOptions.json");
}

<div id="@Html.IdFor(m => m)" class="type-part-editor type-part-editor-monaco monaco-json-settings-editor" data-schema-uri="@IStandaloneEditorConstructionOptionsSchemaPath">
    <div class="ocat-wrapper">
        <label asp-for="Options" class="ocat-label">@T["Enter the editor options, language is always set to `html` when saved."]</label>
        <div class="ocat-end">
            <div id="@Html.IdFor(m => m)_editor" style="min-height: 200px;" class="form-control monaco-json-settings-editor-container"></div>
            <span class="hint"><a href="https://microsoft.github.io/monaco-editor/docs.html#interfaces/editor_editor_api.editor.IStandaloneEditorConstructionOptions.html" target="_blank">@T["Documentation for options"]</a></span>
            <textarea asp-for="Options" hidden class="monaco-json-settings-editor-value">@Html.Raw(Model.Options)</textarea>
        </div>
    </div>
</div>
<script asp-name="monaco" at="Foot"></script>
<script asp-src="~/OrchardCore.Html/Scripts/html-body-part-editors/html-body-part-monaco-settings.min.js" debug-src="~/OrchardCore.Html/Scripts/html-body-part-editors/html-body-part-monaco-settings.js" depends-on="monaco" at="Foot" type="module"></script>
