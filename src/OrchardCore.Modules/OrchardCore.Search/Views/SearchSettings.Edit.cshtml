@model SearchSettingsViewModel

@if (Model.Indexes?.Count > 0)
{
    <div class="ocat-wrapper" asp-validation-class-for="DefaultIndexProfileName">
        <label asp-for="DefaultIndexProfileName" class="ocat-label">@T["Default search index"]</label>
        <div class="ocat-end">
            <select asp-for="DefaultIndexProfileName" asp-items="Model.Indexes" class="form-select">
                <option value="">@T["Select a default index"]</option>
            </select>
            <span asp-validation-for="DefaultIndexProfileName"></span>
            <span class="hint">@T["The default index to use for the search page."]</span>
        </div>
    </div>

    <div class="ocat-wrapper" asp-validation-class-for="Placeholder">
        <label asp-for="Placeholder" class="ocat-label">@T["Placeholder"]</label>
        <div class="ocat-end">
            <input type="text" class="form-control" asp-for="Placeholder" />
            <span class="hint">@T["The placeholder text to use in the search bar."]</span>
        </div>
    </div>
}
else
{
    <div class="ocat-wrapper">
        <div class="ocat-end-offset">
            <div class="alert alert-warning">@T["No available indexes. Add at least one index to search."]</div>
        </div>
    </div>
}
