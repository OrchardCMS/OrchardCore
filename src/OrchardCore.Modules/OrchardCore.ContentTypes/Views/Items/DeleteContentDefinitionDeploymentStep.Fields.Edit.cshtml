@model DeleteContentDefinitionStepViewModel

<div class="ocat-wrapper" asp-validation-class-for="ContentTypes">
    <label asp-for="ContentTypes" class="ocat-label">@T["Content Type Definitions"]</label>
    <div class="ocat-end">
        <input asp-for="ContentTypes" class="form-control" type="text" />
        <span asp-validation-for="ContentTypes"></span>
        <span class="hint">@T["A comma separated list of content type definitions to delete"]</span>
    </div>
</div>

<div class="ocat-wrapper" asp-validation-class-for="ContentParts">
    <label asp-for="ContentParts" class="ocat-label">@T["Content Part Definitions"]</label>
    <div class="ocat-end">
        <input asp-for="ContentParts" class="form-control" type="text" />
        <span asp-validation-for="ContentParts"></span>
        <span class="hint">@T["A comma separated list of content part definitions to delete"]</span>
    </div>
</div>
