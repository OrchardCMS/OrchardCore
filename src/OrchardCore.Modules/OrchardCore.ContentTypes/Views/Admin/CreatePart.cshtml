@model CreatePartViewModel

<zone Name="Title"><h1>@RenderTitleSegments(T["New Content Part"])</h1></zone>

<form asp-action="CreatePart">
    @Html.ValidationSummary()

    <div class="@Orchard.GetLimitedWidthWrapperClasses("mb-3")">
        <label asp-for="Name" class="@Orchard.GetLabelClasses()">@T["Name"]</label>
        <div class="@Orchard.GetLimitedWidthClasses()">
            <input asp-for="Name" class="form-control" autofocus="autofocus" />
            <span class="hint">@T["Use no spaces or special characters. For example, \"MyCustomPart\""]</span>
        </div>
    </div>

    <div class="@Orchard.GetWrapperClasses()">
        <div class="@Orchard.GetEndClasses(true)">
            <button class="btn btn-primary create" type="submit">@T["Create"]</button>
        </div>
    </div>
</form>
