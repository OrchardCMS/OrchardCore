@model DeploymentPlanDeploymentStepViewModel

@{
    var deploymentPlanNames = Model.DeploymentPlanNames;
    var allDeploymentPlanNames = Model.AllDeploymentPlanNames;
}

<div class="ocat-wrapper">
    <div class="ocat-end-offset">
        <h5>@T["Deployment Plans"]</h5>
    </div>
</div>

<div class="ocat-wrapper" asp-validation-class-for="IncludeAll">
    <div class="ocat-end-offset">
        <div class="form-check">
            <input class="form-check-input" asp-for="IncludeAll" data-reverseToggle=".dpsel" />
            <label class="form-check-label" asp-for="IncludeAll">@T["Include all deployment plans."]</label>
        </div>
    </div>
</div>

<div class="dpsel @(Model.IncludeAll ? "collapse" : "show")">
    <div class="ocat-wrapper">
        <div class="ocat-end-offset">
            <span class="hint">@T["The deployment plans to add as part of the plan."]</span>
        </div>
    </div>
    <div class="ocat-wrapper">
        <div class="ocat-end-offset">
            <ul class="list-group">
                @foreach (var deploymentPlanName in allDeploymentPlanNames)
                {
                    var checkd = deploymentPlanNames?.Contains(deploymentPlanName);

                    <li class="list-group-item">
                        <div class="form-check">
                            <label class="form-check-label">
                                <input class="form-check-input" type="checkbox" name="@Html.NameFor(m => m.DeploymentPlanNames)" value="@deploymentPlanName" checked="@checkd">
                                @deploymentPlanName
                            </label>
                        </div>
                    </li>
                }
            </ul>
        </div>
    </div>
</div>

<script asp-src="~/OrchardCore.Deployment/Scripts/deployment-step-editors/deployment-plan-deployment-step.min.js" debug-src="~/OrchardCore.Deployment/Scripts/deployment-step-editors/deployment-plan-deployment-step.js" at="Foot" type="module"></script>
