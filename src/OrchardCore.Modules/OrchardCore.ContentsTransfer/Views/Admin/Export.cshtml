@using Microsoft.Extensions.Options
@using OrchardCore
@using OrchardCore.ContentsTransfer

@model ContentExporterViewModel

@inject IOptions<ContentImportOptions> ContentImportOptions

<zone Name="Title"><h1>@RenderTitleSegments(T["Export Contents"])</h1></zone>

<div class="card text-bg-theme mb-3">
    <div class="card-header fw-bold">@T["Export contents"]</div>
    <div class="card-body">
        @if (Model.ContentTypes.Count == 0)
        {
            <div class="alert alert-info mb-0">
                @T["No content types are configured for bulk export. Enable bulk export in the content type settings."]
            </div>
        }
        else
        {
        <form id="export-form" asp-action="DownloadExport" asp-controller="Admin" method="get">
            <div class="@Orchard.GetWrapperClasses()">
                <label asp-for="Extension" class="@Orchard.GetLabelClasses()">@T["File type"]</label>
                <div class="@Orchard.GetEndClasses()">
                    <select asp-for="Extension" asp-items="Model.Extensions" class="form-select">
                    </select>
                </div>
            </div>
            <div class="@Orchard.GetWrapperClasses()">
                <label asp-for="ContentTypeId" class="@Orchard.GetLabelClasses()">@T["Content type"]</label>
                <div class="@Orchard.GetEndClasses()">
                    <select asp-for="ContentTypeId" asp-items="Model.ContentTypes" class="form-select">
                        <option value="">@T["Select type to export"]</option>
                    </select>
                </div>
            </div>

            <div class="@Orchard.GetWrapperClasses()">
                <label class="@Orchard.GetLabelClasses()">@T["Export scope"]</label>
                <div class="@Orchard.GetEndClasses()">
                    <div class="form-check form-check-inline">
                        <input class="form-check-input" type="radio" name="PartialExport" id="exportAll" value="false" checked>
                        <label class="form-check-label" for="exportAll">@T["Export all published"]</label>
                    </div>
                    <div class="form-check form-check-inline">
                        <input class="form-check-input" type="radio" name="PartialExport" id="exportPartial" value="true">
                        <label class="form-check-label" for="exportPartial">@T["Partial Export"]</label>
                    </div>
                </div>
            </div>

            <div id="partial-export-filters" style="display: none;">
                <hr />
                <h6 class="text-muted mb-3">@T["Filter Options"]</h6>

                <div class="@Orchard.GetWrapperClasses()">
                    <label asp-for="CreatedFrom" class="@Orchard.GetLabelClasses()">@T["Created from"]</label>
                    <div class="@Orchard.GetEndClasses()">
                        <input asp-for="CreatedFrom" type="date" class="form-control" />
                    </div>
                </div>
                <div class="@Orchard.GetWrapperClasses()">
                    <label asp-for="CreatedTo" class="@Orchard.GetLabelClasses()">@T["Created to"]</label>
                    <div class="@Orchard.GetEndClasses()">
                        <input asp-for="CreatedTo" type="date" class="form-control" />
                    </div>
                </div>

                <div class="@Orchard.GetWrapperClasses()">
                    <label asp-for="ModifiedFrom" class="@Orchard.GetLabelClasses()">@T["Modified from"]</label>
                    <div class="@Orchard.GetEndClasses()">
                        <input asp-for="ModifiedFrom" type="date" class="form-control" />
                    </div>
                </div>
                <div class="@Orchard.GetWrapperClasses()">
                    <label asp-for="ModifiedTo" class="@Orchard.GetLabelClasses()">@T["Modified to"]</label>
                    <div class="@Orchard.GetEndClasses()">
                        <input asp-for="ModifiedTo" type="date" class="form-control" />
                    </div>
                </div>

                <div class="@Orchard.GetWrapperClasses()">
                    <label asp-for="Owners" class="@Orchard.GetLabelClasses()">@T["Owners"]</label>
                    <div class="@Orchard.GetEndClasses()">
                        <input asp-for="Owners" type="text" class="form-control" placeholder="@T["Comma-separated usernames"]" />
                    </div>
                </div>

                <div class="@Orchard.GetWrapperClasses()">
                    <div class="@Orchard.GetEndClasses(true)">
                        <div class="form-check">
                            <input asp-for="PublishedOnly" class="form-check-input" type="checkbox" checked />
                            <label asp-for="PublishedOnly" class="form-check-label">@T["Published only"]</label>
                        </div>
                    </div>
                </div>

                <div class="@Orchard.GetWrapperClasses()">
                    <div class="@Orchard.GetEndClasses(true)">
                        <div class="form-check">
                            <input asp-for="LatestOnly" class="form-check-input" type="checkbox" />
                            <label asp-for="LatestOnly" class="form-check-label">@T["Latest only"]</label>
                        </div>
                    </div>
                </div>

                <div class="@Orchard.GetWrapperClasses()">
                    <div class="@Orchard.GetEndClasses(true)">
                        <div class="form-check">
                            <input asp-for="AllVersions" class="form-check-input" type="checkbox" />
                            <label asp-for="AllVersions" class="form-check-label">@T["All versions"]</label>
                        </div>
                    </div>
                </div>
            </div>

            <div class="@Orchard.GetWrapperClasses()">
                <div class="@Orchard.GetEndClasses(true)">
                    <button type="submit" id="export_contents_button" class="btn btn-primary" disabled>@T["Export Data"]</button>
                </div>
            </div>
        </form>
        }
    </div>
</div>

@if (Model.ContentTypes.Count > 0)
{
<script at="Foot">
    document.addEventListener('DOMContentLoaded', function () {

        var contentTypeMenu = document.getElementById('@Html.IdFor(x => x.ContentTypeId)');
        var button = document.getElementById('export_contents_button');
        var exportAllRadio = document.getElementById('exportAll');
        var exportPartialRadio = document.getElementById('exportPartial');
        var filtersPanel = document.getElementById('partial-export-filters');
        var allVersionsCheck = document.getElementById('@Html.IdFor(x => x.AllVersions)');
        var publishedCheck = document.getElementById('@Html.IdFor(x => x.PublishedOnly)');
        var latestCheck = document.getElementById('@Html.IdFor(x => x.LatestOnly)');

        contentTypeMenu.addEventListener('change', updateButton);
        exportAllRadio.addEventListener('change', toggleFilters);
        exportPartialRadio.addEventListener('change', toggleFilters);

        // Make checkboxes mutually exclusive.
        allVersionsCheck.addEventListener('change', function () {
            if (this.checked) {
                publishedCheck.checked = false;
                latestCheck.checked = false;
            }
        });
        publishedCheck.addEventListener('change', function () {
            if (this.checked) {
                allVersionsCheck.checked = false;
            }
        });
        latestCheck.addEventListener('change', function () {
            if (this.checked) {
                allVersionsCheck.checked = false;
            }
        });

        function toggleFilters() {
            filtersPanel.style.display = exportPartialRadio.checked ? '' : 'none';
        }

        function updateButton() {
            if (!contentTypeMenu.value) {
                button.setAttribute('disabled', 'disabled');
            } else {
                button.removeAttribute('disabled');
            }
        }
    }, false);

</script>
}
