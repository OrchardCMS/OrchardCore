@using OrchardCore
@model AllConditionViewModel

<h5>@T["All"]</h5>

<div class="@Orchard.GetWrapperClasses()" asp-validation-class-for="DisplayText">
    <label asp-for="DisplayText" class="@Orchard.GetLabelClasses()">@T["Name"]</label>
    <div class="@Orchard.GetEndClasses()">
        <input asp-for="DisplayText" class="form-control" type="text" />
        <span asp-validation-for="DisplayText"></span>
    </div>
</div>
