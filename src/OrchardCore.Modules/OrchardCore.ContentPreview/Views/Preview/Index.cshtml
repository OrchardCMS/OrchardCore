@{
    Layout = "_Layout";
    var previewId = ViewContext.RouteData.Values["id"];
}

<iframe id="iframe-a" title="preview" data-preview-id="@previewId" style="position:fixed; top:0; left:0; bottom:0; right:0; width:100%; height:100%; border:none; margin:0; padding:0; overflow:hidden; z-index:999990;"></iframe>
<iframe id="iframe-b" title="preview-staging" style="position:fixed; top:0; left:0; bottom:0; right:0; width:100%; height:100%; border:none; margin:0; padding:0; overflow:hidden; z-index:999989;"></iframe>

<div id="notConnectedWarning" class="alert alert-info alert-dismissible fade show" role="alert" style="position:fixed; height:60px; top:10px; right:40px; display:none; z-index:999999;">
    <button type="button" id="close-connect-warning" class="btn-close" aria-label="Close" style="position:relative; padding:0 0 0 1rem; margin-top:-0.2rem;"></button>
    <span>@T["Preview Disconnected"] </span>
</div>

<div id="serverErrorWarning" class="alert alert-warning alert-dismissible fade show" role="alert" style="position:fixed; top:10px; right:40px; display:none; z-index:999999;">
    <button type="button" id="close-server-warning" class="btn-close" aria-label="Close" style="position:relative; padding:0 0 0 1rem; margin-top:-0.2rem;"></button>
    <p>@T["Preview Error"] </p>
    <ul></ul>
</div>

<resources type="Footer" />

<script asp-src="~/OrchardCore.ContentPreview/Scripts/preview-swap/preview-swap.min.js" debug-src="~/OrchardCore.ContentPreview/Scripts/preview-swap/preview-swap.js" type="module"></script>
