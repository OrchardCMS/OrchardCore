@{
    var editorId = (string)Model.EditorId;
    var textAreaId = (string)Model.TextAreaId;
    var language = (string)Model.Language;
    var options = (string)Model.Options ?? "{}";
    var contentPreview = (bool?)Model.ContentPreview ?? false;
    var readOnly = (bool?)Model.ReadOnly ?? false;

    // Use a unique key per editor to avoid duplicate initialization.
    var editorKey = $"MonacoEditor_{editorId}";
}

<script asp-name="monaco" at="Foot"></script>
<script at="Foot" depends-on="monaco">
@if (!Context.Items.ContainsKey("MonacoEditor_ThemeHelper"))
{
    Context.Items["MonacoEditor_ThemeHelper"] = true;

    <text>
    (function () {
        if (window.__monacoThemeObserverInitialized) return;
        window.__monacoThemeObserverInitialized = true;

        function setMonacoTheme() {
            var html = document.documentElement;
            var theme = html.dataset.bsTheme;
            if (theme === 'dark' || (theme === 'auto' && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
                monaco.editor.setTheme('vs-dark');
            } else {
                monaco.editor.setTheme('vs');
            }
        }

        require(['vs/editor/editor.main'], function () {
            var html = document.documentElement;
            new MutationObserver(setMonacoTheme).observe(html, { attributes: true });
            setMonacoTheme();
        });
    })();
    </text>
}

    (function () {
        function initEditor() {
            require(['vs/editor/editor.main'], function () {
                var divEditor = document.getElementById('@editorId');
                if (!divEditor) return;

                var settings = @Html.Raw(string.IsNullOrWhiteSpace(options) ? "{}" : options);
                if (settings.automaticLayout == undefined) {
                    settings.automaticLayout = true;
                }
@if (!string.IsNullOrEmpty(language))
{
                    <text>settings.language = settings.language || '@language';</text>
}
@if (readOnly)
{
                    <text>settings.readOnly = true;</text>
}

                var editor = monaco.editor.create(divEditor, settings);
                var textArea = document.getElementById('@textAreaId');

                editor.getModel().setValue(textArea.value);

                window.addEventListener('submit', function () {
                    textArea.value = editor.getValue();
                });
@if (contentPreview)
{
                    <text>
                editor.getModel().onDidChangeContent(function () {
                    textArea.value = editor.getValue();
                    $(document).trigger('contentpreview:render');
                });
                    </text>
}
            });
        }

        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', initEditor);
        } else {
            initEditor();
        }
    })();
</script>
