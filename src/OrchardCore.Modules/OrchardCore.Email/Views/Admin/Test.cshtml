@model OrchardCore.Email.ViewModels.EmailTestViewModel

<zone Name="Title"><h1>@RenderTitleSegments(T["Settings"])</h1></zone>

@if (Model.Providers == null || Model.Providers.Count == 0)
{
    <div class="alert alert-danger" role="alert">
        @T["No email providers are currently enabled. Please enable at least one email provider feature."]
    </div>

    return;
}

<form method="post" class="no-multisubmit">
    @Html.ValidationSummary()

    <div class="ocat-wrapper">
        <label asp-for="Provider" class="ocat-label">@T["Provider"]</label>
        <div class="ocat-end">
            <select class="form-select" asp-for="Provider" asp-items="Model.Providers">
                <option value="">@T["Select a provider"]</option>
            </select>
        </div>
    </div>

    <div class="ocat-wrapper" asp-validation-class-for="To">
        <label asp-for="To" class="ocat-label">@T["To"]</label>
        <div class="ocat-end">
            <input asp-for="To" class="form-control" type="text" />
            <span asp-validation-for="To"></span>
        </div>
    </div>

    <div class="ocat-wrapper" asp-validation-class-for="From">
        <label asp-for="From" class="ocat-label">@T["Sender"]</label>
        <div class="ocat-end">
            <input asp-for="From" class="form-control" type="text" />
            <span asp-validation-for="From"></span>
            <span class="hint">@T["The sender is optional, it is useful when the email author is different than the email submitter."]</span>
        </div>
    </div>

    <div class="ocat-wrapper" asp-validation-class-for="Cc">
        <label asp-for="Cc" class="ocat-label">@T["Cc"]</label>
        <div class="ocat-end">
            <input asp-for="Cc" class="form-control" type="text" />
            <span asp-validation-for="Cc"></span>
        </div>
    </div>

    <div class="ocat-wrapper" asp-validation-class-for="Bcc">
        <label asp-for="Bcc" class="ocat-label">@T["Bcc"]</label>
        <div class="ocat-end">
            <input asp-for="Bcc" class="form-control" type="text" />
            <span asp-validation-for="Bcc"></span>
        </div>
    </div>

    <div class="ocat-wrapper" asp-validation-class-for="ReplyTo">
        <label asp-for="ReplyTo" class="ocat-label">@T["Reply To"]</label>
        <div class="ocat-end">
            <input asp-for="ReplyTo" class="form-control" type="text" />
            <span asp-validation-for="ReplyTo"></span>
        </div>
    </div>

    <div class="ocat-wrapper" asp-validation-class-for="Subject">
        <label asp-for="Subject" class="ocat-label">@T["Subject"]</label>
        <div class="ocat-end">
            <input asp-for="Subject" class="form-control" type="text" required />
            <span asp-validation-for="Subject"></span>
        </div>
    </div>

    <div class="ocat-wrapper" asp-validation-class-for="Body">
        <label asp-for="Body" class="ocat-label">@T["Body"]</label>
        <div class="ocat-end">
            <textarea asp-for="Body" class="form-control" rows="5"></textarea>
            <span asp-validation-for="Body"></span>
        </div>
    </div>

    <div class="ocat-wrapper">
        <div class="ocat-end-offset">
            <button type="submit" class="btn btn-primary">@T["Send"]</button>
        </div>
    </div>
</form>
