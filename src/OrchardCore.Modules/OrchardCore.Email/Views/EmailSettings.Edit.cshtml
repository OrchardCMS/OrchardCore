@using Microsoft.Extensions.Options
@using OrchardCore.Email.Services
@using OrchardCore.Email.ViewModels

@model EmailSettingsViewModel

@inject IOptions<EmailProviderOptions> EmailProviderOptions

@if (Model.Providers.Count == 0)
{
    <div class="ocat-wrapper">
        <div class="ocat-end-offset">
            <div class="alert alert-warning" role="alert">
                @T["No email providers are currently enabled."]
            </div>
        </div>
    </div>

    return;
}

<div class="ocat-wrapper" asp-validation-class-for="DefaultProvider">
    <label asp-for="DefaultProvider" class="ocat-label">@T["Default provider"]</label>
    <div class="ocat-end">
        <select asp-for="DefaultProvider" class="form-select" asp-items="Model.Providers"></select>
        <span asp-validation-for="DefaultProvider"></span>
    </div>
</div>
