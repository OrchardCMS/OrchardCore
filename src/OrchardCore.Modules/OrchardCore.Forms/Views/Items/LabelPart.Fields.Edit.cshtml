@using OrchardCore
@using OrchardCore.Forms.ViewModels
@model LabelPartEditViewModel

<div class="ocat-wrapper">
    <label asp-for="For" class="ocat-label">@T["For"]</label>
    <div class="ocat-end">
        <input asp-for="For" type="text" class="form-control content-preview-text" />
        <span class="hint">@T["The ID of the form element to associate with this label."]</span>
    </div>
</div>
