@using OrchardCore
@using OrchardCore.Forms.Workflows.ViewModels
@model ValidateFormFieldTaskViewModel

<div class="ocat-wrapper" asp-validation-class-for="FieldName">
    <label asp-for="FieldName" class="ocat-label">@T["Field Name"]</label>
    <div class="ocat-end">
        <input type="text" asp-for="FieldName" class="form-control" />
        <span asp-validation-for="FieldName"></span>
        <span class="hint">@T["The name of the form field to validate."]</span>
    </div>
</div>

<div class="ocat-wrapper" asp-validation-class-for="ErrorMessage">
    <label asp-for="ErrorMessage" class="ocat-label">@T["Error Message"]</label>
    <div class="ocat-end">
        <input type="text" asp-for="ErrorMessage" class="form-control" />
        <span asp-validation-for="ErrorMessage"></span>
        <span class="hint">@T["The validation error message to display."]</span>
    </div>
</div>
