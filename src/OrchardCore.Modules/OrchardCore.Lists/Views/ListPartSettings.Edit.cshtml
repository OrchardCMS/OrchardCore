@model OrchardCore.Lists.ViewModels.ListPartSettingsViewModel

<div class="ocat-wrapper" asp-validation-class-for="PageSize">
    <label asp-for="PageSize" class="ocat-label">@T["Page Size"]</label>
    <div class="ocat-end">
        <input asp-for="PageSize" class="form-control" />
        <span asp-validation-for="PageSize" class="text-danger"></span>
        <span class="hint">@T["The number of items to display per page."]</span>
    </div>
</div>

<div class="ocat-wrapper">
    <div class="ocat-end-offset">
        <div class="form-check">
            <input type="checkbox" class="form-check-input" asp-for="EnableOrdering">
            <label class="form-check-label" asp-for="EnableOrdering">@T["Enable Ordering"]</label>
            <span class="hint dashed">@T["Check this option to enable manual ordering of items."]</span>
        </div>
    </div>
</div>

<div class="ocat-wrapper">
    <label asp-for="ContainedContentTypes" class="ocat-label">@T["Contained Content Types"]</label>
    <div class="ocat-end">
        <span class="hint">@T["The content types that this list can contain, e.g. Blog Post for a Blog."]</span>
        @await Component.InvokeAsync("SelectContentTypes", new { selectedContentTypes = Model.ContainedContentTypes, htmlName = Html.NameFor(m => m.ContainedContentTypes) })
    </div>
</div>

<div class="ocat-wrapper">
    <div class="ocat-end-offset">
        <div class="form-check">
            <input type="checkbox" class="form-check-input" asp-for="ShowHeader">
            <label class="form-check-label" asp-for="ShowHeader">@T["Show container's header"]</label>
            <span class="hint dashed">@T["Check this option to show a header for the owning content."]</span>
        </div>
    </div>
</div>

<div class="ocat-wrapper">
    <div class="ocat-end-offset">
        <div class="form-check">
            <input type="checkbox" class="form-check-input" asp-for="ShowFullPager" />
            <label class="form-check-label" asp-for="ShowFullPager">@T["Show full pager"]</label>
            <span class="hint dashed">@T["When enabled, the list uses a full pager with numbered pages. Note: This requires an additional database query to determine the total item count."]</span>
        </div>
    </div>
</div>
