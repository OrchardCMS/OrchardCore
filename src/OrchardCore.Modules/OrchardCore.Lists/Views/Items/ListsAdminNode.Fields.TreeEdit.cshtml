@model ListsAdminNodeViewModel
@{
    var parentIconWrapperClasses = Model.AddContentTypeAsParent
        ? "ocat-wrapper icon-picker-for-content-type"
        : "ocat-wrapper icon-picker-for-content-type collapse";
}

<style asp-src="~/OrchardCore.AdminMenu/Styles/admin-menu-icon-picker.min.css" debug-src="~/OrchardCore.AdminMenu/Styles/admin-menu-icon-picker.css" at="Head"></style>

<script asp-name="vuejs" at="Foot" version="2"></script>
<script asp-src="~/OrchardCore.AdminMenu/Scripts/admin-menu-icon-picker.min.js" debug-src="~/OrchardCore.AdminMenu/Scripts/admin-menu-icon-picker.js" at="Foot" depends-on="bootstrap, jQuery, jQuery.nestedSortable:2.1, fontawesome-iconpicker"></script>

<div class="ocat-wrapper">
    <div class="ocat-end-offset">
        <h5 class="mb-0">@T["Lists"]</h5>
    </div>
</div>

<div class="mb-4">
    <div class="ocat-wrapper">
        <label asp-for="ContentType" class="ocat-label">@T["Content type"]</label>
        <div class="ocat-end">
            <select asp-for="ContentType" asp-items="Model.ContentTypes" class="form-select">
                <option value="">@T["Select a content type"]</option>
            </select>
        </div>
    </div>

    <div class="ocat-wrapper">
        <label asp-for="IconForContentItems" class="ocat-label">@T["Icon for the content items"]</label>
        <div class="ocat-end">
            <div class="btn-toolbar icon-toolbar" role="toolbar" aria-label="Icon Selector Toolbar">
                <div class="btn-group input-group me-2" role="group" aria-label="Icon Selector">
                    <button type="button" class="btn btn-primary sample-icon">
                        <i id="@("sample-icon-" + Html.IdFor(m => m.IconForContentItems))"
                           class="@(Model.IconForContentItems)"></i>
                    </button>
                    <input type="hidden" name="@Html.NameFor(m => m.IconForContentItems)"
                           id="@Html.IdFor(m => m.IconForContentItems)" class="icon-val"
                           value="@Model.IconForContentItems" />
                    <button type="button"
                            class="btn btn-primary icon-picker-trigger"
                            data-related-node="@Html.IdFor(m => m.IconForContentItems)">
                        @T["Icon"]
                    </button>
                </div>

                <div class="btn-group" role="group" aria-label="Remove Icon Button">
                    <button type="button" class="btn btn-secondary remove-icon"
                            data-related-node="@Html.IdFor(m => m.IconForContentItems)">
                        <div style="pointer-events:none;">
                            <i class="fa-solid fa-trash" aria-hidden="true"></i>
                        </div>
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div class="ocat-wrapper add-parent-link-fieldset">
        <div class="ocat-end-offset">
            <div class="form-check">
                <input asp-for="AddContentTypeAsParent" class="form-check-input add-parent-link-checkbox" />
                <label class="form-check-label" asp-for="AddContentTypeAsParent">@T["Add parent menu item"]</label>
                <span class="hint">@T["Determines if there will be a parent item containing the content item links."]</span>
            </div>
        </div>
    </div>

    <div class="@parentIconWrapperClasses">
        <label asp-for="IconForParentLink" class="ocat-label">@T["Icon for the parent menu item"]</label>
        <div class="ocat-end">
            <div class="btn-toolbar icon-toolbar" role="toolbar" aria-label="Icon Selector Toolbar">
                <div class="btn-group input-group me-2" role="group" aria-label="Icon Selector">
                    <button type="button" class="btn btn-primary sample-icon">
                        <i id="@("sample-icon-" + Html.IdFor(m => m.IconForParentLink))"
                           class="@(Model.IconForParentLink)"></i>
                    </button>
                    <input type="hidden" name="@Html.NameFor(m => m.IconForParentLink)"
                           id="@Html.IdFor(m => m.IconForParentLink)" class="icon-val"
                           value="@Model.IconForParentLink" />
                    <button type="button"
                            class="btn btn-primary icon-picker-trigger"
                            data-related-node="@Html.IdFor(m => m.IconForParentLink)">
                        @T["Icon"]
                    </button>
                </div>

                <div class="btn-group" role="group" aria-label="Remove Icon Button">
                    <button type="button" class="btn btn-secondary remove-icon"
                            data-related-node="@Html.IdFor(m => m.IconForParentLink)">
                        <div style="pointer-events:none;">
                            <i class="fa-solid fa-trash" aria-hidden="true"></i>
                        </div>
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<div id="iconPickerVue">
    <div class="modal" id="iconPickerModal" tabindex="-1" role="dialog" aria-labelledby="iconPickerModal" aria-hidden="true">
        <div class="modal-dialog" role="dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@T["Pick an icon"]</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body p-0">
                    <div id="inline-picker" class="icp icp-auto" data-placement="inline"></div>
                </div>
            </div>
        </div>
    </div>
</div>

<script at="Foot">
    document.addEventListener('DOMContentLoaded', function () {
        document.querySelectorAll('.add-parent-link-checkbox').forEach(function (checkbox) {
            checkbox.addEventListener('click', function (e) {
                var fieldSet = e.currentTarget.closest('.add-parent-link-fieldset');
                var iconPickerFieldSets = Array.from(fieldSet.parentElement.children).filter(function (element) {
                    return element !== fieldSet && element.classList.contains('icon-picker-for-content-type');
                });
                var selected = e.currentTarget.checked;
                console.log(iconPickerFieldSets[0]);
                iconPickerFieldSets.forEach(function (iconPickerFieldSet) {
                    selected ? iconPickerFieldSet.classList.remove('collapse') : iconPickerFieldSet.classList.add('collapse');
                });
            });
        });

        document.querySelectorAll('.icon-picker-trigger').forEach(function (trigger) {
            trigger.addEventListener('click', function (e) {
                var node = e.currentTarget.dataset.relatedNode;
                iconPickerVue.show(node, 'sample-icon-' + node);
            });
        });

        document.querySelectorAll('button.remove-icon').forEach(function (button) {
            button.addEventListener('click', function (e) {
                var node = e.currentTarget.dataset.relatedNode;
                var input = document.getElementById(node);
                if (input) {
                    input.value = '';
                }

                var sampleIcon = document.getElementById('sample-icon-' + node);
                if (sampleIcon) {
                    sampleIcon.outerHTML = '<i id="sample-icon-' + node + '" class=" "></i>'; // changing the class is not enough.
                }
            });
        });
    });
</script>
