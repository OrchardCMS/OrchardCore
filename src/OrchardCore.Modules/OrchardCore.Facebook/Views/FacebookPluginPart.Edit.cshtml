@model OrchardCore.Facebook.Widgets.ViewModels.FacebookPluginPartViewModel
<style asp-name="codemirror"></style>
<script asp-name="codemirror" at="Foot"></script>
<script asp-name="codemirror-mode-javascript" at="Foot"></script>
<script asp-name="codemirror-addon-display-autorefresh" at="Foot"></script>
<script asp-name="codemirror-addon-mode-simple" at="Foot"></script>
<script asp-name="codemirror-addon-mode-multiplex" at="Foot"></script>
<script asp-name="codemirror-mode-xml" at="Foot"></script>
<script asp-src="~/OrchardCore.Liquid/codemirror/liquid.js" at="Foot"></script>

<div class="ocat-wrapper">
    <label asp-for="Liquid" class="ocat-label">@T["Body"]</label>
    <div class="ocat-end">
        <textarea asp-for="Liquid" rows="5" class="form-control content-preview-text facebook-plugin-part-editor"></textarea>
        <span class="hint">@T["The template of the plugin, in Liquid format."]</span>
    </div>
</div>

<script asp-src="~/OrchardCore.Facebook/Scripts/facebook-plugin-part-editors/facebook-plugin-part.min.js" debug-src="~/OrchardCore.Facebook/Scripts/facebook-plugin-part-editors/facebook-plugin-part.js" at="Foot" type="module"></script>
