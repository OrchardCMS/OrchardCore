@model ReCaptchaSettingsViewModel

<div class="ocat-wrapper" asp-validation-class-for="SiteKey">
    <label asp-for="SiteKey" class="ocat-label">@T["Site Key"]</label>
    <div class="ocat-end">
        <input asp-for="SiteKey" class="form-control" type="text" />
        <span asp-validation-for="SiteKey"></span>
        <span class="hint">@T["Your Google's reCaptcha Site Key."]</span>
    </div>
</div>

<div class="ocat-wrapper" asp-validation-class-for="SecretKey">
    <label asp-for="SecretKey" class="ocat-label">@T["Secret Key"]</label>
    <div class="ocat-end">
        <input asp-for="SecretKey" class="form-control" type="text" autocomplete="off" />
        <span asp-validation-for="SecretKey"></span>
        <span class="hint">@T["Your Google's reCaptcha Secret Key."]</span>
    </div>
</div>

<div class="ocat-wrapper">
    <div class="ocat-end-offset">
        <span class="hint">@T["Get your reCaptcha at"] <a href="https://developers.google.com/recaptcha/" target="_blank">https://developers.google.com/recaptcha/</a></span>
    </div>
</div>
