@model OrchardCore.Flows.ViewModels.BagPartBlocksEditorSettingsViewModel

<div id="@Html.IdFor(m => m)" class="type-part-editor type-part-editor-blocks">
    <div class="ocat-wrapper">
        <label asp-for="AddButtonText" class="ocat-label">@T["Add Button Text"]</label>
        <div class="ocat-end">
            <input asp-for="AddButtonText" class="form-control" placeholder="@T["Add Block"]" />
            <span class="hint">@T["(Optional) Custom text for the add button. Leave empty for default."]</span>
        </div>
    </div>

    <div class="ocat-wrapper">
        <label asp-for="ModalTitleText" class="ocat-label">@T["Modal Title Text"]</label>
        <div class="ocat-end">
            <input asp-for="ModalTitleText" class="form-control" placeholder="@T["Select Block"]" />
            <span class="hint">@T["(Optional) Custom text for the content type picker modal title. Leave empty for default."]</span>
        </div>
    </div>
</div>
