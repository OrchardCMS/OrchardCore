@using OrchardCore.ContentManagement.Metadata.Settings
@using OrchardCore.DisplayManagement.Theming
@using OrchardCore.Flows.Extensions
@using OrchardCore.Flows.Models
@using OrchardCore.Flows.ViewModels
@using OrchardCore.Mvc.Utilities
@using System.Text.Json;
@model BagPartEditViewModel
@inject IContentManager ContentManager
@inject OrchardCore.ContentManagement.Display.IContentItemDisplayManager ContentItemDisplayManager
@{
    var widgetTemplatePlaceholderId = Html.Id("widgetTemplatePlaceholder");
    var htmlFieldPrefix = ViewContext.ViewData.TemplateInfo.HtmlFieldPrefix;
    var contentTypesStringified = string.Join(";", Model.ContainedContentTypeDefinitions.Select(x => x.Name));
    var parentContentType = Model.BagPart.ContentItem.ContentType;
    string partName = ((dynamic)Model).Metadata.Name;
    var totalItems = Model.ContainedContentTypeDefinitions.Count();
    // Unique ID for this instance's button
    var buttonId = Html.Id("openContentTypePicker");
}

<div class="mb-3">
    <div id="@widgetTemplatePlaceholderId"
         class="widget-template-placeholder widget-template-placeholder-bagpart bagpart-@partName.HtmlClassify() row mx-0 bagpart-blocks-sortable-placeholder"
         data-buildeditorurl="@Url.Action("BuildEditor", "Admin", new { area = "OrchardCore.Flows" })"
         data-content-types="@contentTypesStringified"
         data-part-name="@partName">
        @{
            var index = 0;
        }
        @foreach (var widget in Model.AccessibleWidgets)
        {
            dynamic contentCard = await New.ContentCard(
                CollectionShape: Model,
                CollectionShapeType: nameof(BagPart),
                ContentItem: widget.ContentItem,
                BuildEditor: widget.Editable,
                ParentContentType: parentContentType,
                CollectionPartName: partName,
                TargetId: widgetTemplatePlaceholderId,
                Inline: false,
                CanMove: widget.Editable,
                CanDelete: widget.Deletable,
                HtmlFieldPrefix: htmlFieldPrefix,
                PrefixValue: htmlFieldPrefix + '-' + (index++).ToString(),
                PrefixesId: Html.IdFor(x => x.Prefixes),
                PrefixesName: Html.NameFor(x => x.Prefixes),
                ContentTypesId: Html.IdFor(x => x.ContentTypes),
                ContentTypesName: Html.NameFor(x => x.ContentTypes),
                ContentItemsId: Html.IdFor(x => x.ContentItems),
                ContentItemsName: Html.NameFor(x => x.ContentItems)
            );
            @await DisplayAsync(contentCard)
        }
    </div>

    @if (totalItems == 1)
    {
        @* Single content type - direct add button (same as standard BagPart) *@
        var type = Model.ContainedContentTypeDefinitions.First();
        <a class="btn btn-primary add-widget btn-sm"
           data-target-id="@widgetTemplatePlaceholderId"
           data-html-field-prefix="@htmlFieldPrefix"
           data-prefixes-name="@Html.NameFor(x => x.Prefixes)"
           data-contenttypes-name="@Html.NameFor(x => x.ContentTypes)"
           data-contentitems-name="@Html.NameFor(x => x.ContentItems)"
           data-widget-type="@type.Name"
           data-flowmetadata="false"
           data-parent-content-type="@parentContentType"
           data-part-name="@partName"
           href="javascript:;">
            <i class="fa fa-plus" aria-hidden="true"></i> @T["Add {0}", type.DisplayName]
        </a>
    }
    else if (totalItems > 1)
    {
        @* Multiple content types - show content type picker modal *@
        var contentTypesJson = JsonSerializer.Serialize(
            Model.ContainedContentTypeDefinitions.Select(t => new {
                name = t.Name,
                displayName = t.DisplayName,
                description = t.GetSettings<ContentTypeSettings>()?.Description ?? "",
                category = t.GetCategory(),
                thumbnail = t.GetThumbnail()
            }),
            new JsonSerializerOptions { PropertyNamingPolicy = JsonNamingPolicy.CamelCase }
        );
        <button type="button"
                id="@buttonId"
                class="btn btn-primary btn-sm flow-widget-picker-button bagpart-blocks-picker-button"
                data-target-id="@widgetTemplatePlaceholderId"
                data-content-types="@contentTypesJson"
                data-html-field-prefix="@htmlFieldPrefix"
                data-prefixes-name="@Html.NameFor(x => x.Prefixes)"
                data-content-types-name="@Html.NameFor(x => x.ContentTypes)"
                data-content-items-name="@Html.NameFor(x => x.ContentItems)"
                data-parent-content-type="@parentContentType"
                data-part-name="@partName"
                data-modal-title="@(string.IsNullOrEmpty(Model.ModalTitleText) ? T["Select Block"].Value : Model.ModalTitleText)">
            <i class="fa fa-plus" aria-hidden="true"></i> @(string.IsNullOrEmpty(Model.AddButtonText) ? T["Add Block"] : Model.AddButtonText)
        </button>
    }
</div>

@* Shared resources - rendered once per page *@
@if (Context.Items["BagPart.Edit"] == null)
{
    Context.Items["BagPart.Edit"] = new object();
    <script asp-name="flowpart-edit" at="Foot"></script>
    <style asp-name="flowpart-edit" at="Head"></style>
}

@* Content type picker resources - rendered once per page *@
@if (Context.Items["ContentTypePicker.Init"] == null)
{
    Context.Items["ContentTypePicker.Init"] = new object();
    <script asp-name="content-type-picker" at="Foot"></script>

    @* Shared modal with embedded Vue app - only added to DOM if not already present *@
    <template id="contentTypePickerModalTemplate" data-path-base="@Context.Request.PathBase">
        <div class="modal fade modal-content-type-picker"
             id="contentTypePickerModal"
             tabindex="-1"
             aria-labelledby="contentTypePickerModalLabel"
             aria-hidden="true">
            <div class="modal-dialog modal-xl">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title" id="contentTypePickerModalLabel">@T["Select Block"]</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="@T["Close"]"></button>
                    </div>
                    <div class="modal-body">
                        @await DisplayAsync(await New.ContentTypePicker())
                    </div>
                </div>
            </div>
        </div>
    </template>

}

@* Render mock widgets to ensure resources are included *@
@foreach (var type in Model.ContainedContentTypeDefinitions)
{
    @if (Context.Items["BagPart.Edit:" + type.Name] == null)
    {
        Context.Items["BagPart.Edit:" + type.Name] = new object();
        var contentItem = await ContentManager.NewAsync(type.Name);
        await DisplayAsync(await ContentItemDisplayManager.BuildEditorAsync(contentItem, Model.Updater, true, string.Empty, $"z{Guid.NewGuid():n}"));
    }
}

<script asp-src="~/OrchardCore.Flows/Scripts/flow-blocks-editors/bag-part-blocks.min.js" debug-src="~/OrchardCore.Flows/Scripts/flow-blocks-editors/bag-part-blocks.js" depends-on="flowpart-edit, content-type-picker" at="Foot" type="module"></script>
