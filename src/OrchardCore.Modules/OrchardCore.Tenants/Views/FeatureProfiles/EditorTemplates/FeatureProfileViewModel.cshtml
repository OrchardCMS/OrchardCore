@model FeatureProfileViewModel
@inject OrchardCore.Tenants.Services.IFeatureProfilesSchemaService SchemaService

@{
    var schema = SchemaService.GetJsonSchema();
}

<input type="hidden" asp-for="Id" />

<div class="ocat-limited-wrapper">
    <div class="ocat-limited" asp-validation-class-for="Name">
        <label asp-for="Name" class="ocat-label">@T["Name"]</label>
        <div class="ocat-end">
            <input asp-for="Name" class="form-control" autofocus />
            <span asp-validation-for="Name"></span>
            <span class="hint">@T["The name of the feature profile."]</span>
        </div>
    </div>
</div>

<div class="ocat-wrapper monaco-json-model-editor" asp-validation-class-for="FeatureRules" data-model-uri="x://orchardcore.tenants.featureprofiles.json" data-schema-uri="x://orchardcore.tenants.featureprofiles.schema.json" data-schema="@schema">
    <label asp-for="FeatureRules" class="ocat-label">@T["Rules"]</label>
    <div class="ocat-end">
        <div class="form-control" style="min-height: 400px;">
            <div id="@Html.IdFor(x => x.FeatureRules)_editor" asp-for="FeatureRules" style="min-height: 385px;" dir="@Orchard.CultureDir()" class="monaco-json-model-editor-container"></div>
        </div>
        <textarea asp-for="FeatureRules" hidden class="monaco-json-model-editor-value"></textarea>
        <span asp-validation-for="FeatureRules"></span>
        <span class="hint">
            @T["The feature rules. Here is an example if a rule that would exclude '{0}' feature.", "OrchardCore.Flows"]

<pre>
[
  {
    "Rule": "Exclude",
    "Expression": "OrchardCore.Flows"
  }
]
</pre>
        </span>
    </div>
</div>

<div class="ocat-wrapper">
    <div class="ocat-end-offset">
        <div class="btn-group">
            <button type="submit" name="submit" class="btn btn-primary save">@T["Save"]</button>
            <button type="button" class="btn btn-primary dropdown-toggle dropdown-toggle-split" data-reference="parent" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                <span class="visually-hidden">@T["Toggle Dropdown"]</span>
            </button>
            <div class="dropdown-menu">
                <button class="dropdown-item save-continue" name="submit" type="submit" value="SaveAndContinue">@T["and continue"]</button>
            </div>
        </div>

        <a class="btn btn-secondary cancel" role="button" asp-route-action="Index">@T["Cancel"]</a>
    </div>
</div>
