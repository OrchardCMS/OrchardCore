@model OrchardCore.ContentFields.ViewModels.EditDateFieldViewModel
@using System.Globalization
@using OrchardCore.ContentFields
@using OrchardCore.Localization.Data
@inject IDataLocalizer D
@{
    var settings = Model.PartFieldDefinition.GetSettings<DateFieldSettings>();
    var language = Orchard.CultureName().Split('-')[0];
    var shortDatePattern = CultureInfo.CurrentUICulture.DateTimeFormat.ShortDatePattern;
    var datepickerId = Html.IdFor(m => m.Value);
    string localizedFieldName = D[Model.PartFieldDefinition.DisplayName(), DataLocalizationContext.ContentField(Model.PartFieldDefinition.PartDefinition.Name)];
}

<div class="ocat-wrapper">
    <label asp-for="Value" class="ocat-label @(settings.Required ? "ocat-label-required" : "")">@localizedFieldName</label>
    <div class="ocat-end">
        <div class="ocat-limited-wrapper">
            <div class="ocat-limited">
                @* The value is rendered in ISO 8601 rather than via asp-for's culture-formatted
                   output, since that's the exact format the datepicker keeps this input's posted
                   value in regardless of locale (see date-field-localized.ts). *@
                <input type="text" name="@Html.NameFor(m => m.Value)" id="@datepickerId" value="@(Model.Value?.ToString("yyyy-MM-dd"))" class="form-control content-preview-select datepicker" />
                <span asp-validation-for="Value"></span>
            </div>
        </div>
        @if (!string.IsNullOrEmpty(settings.Hint))
        {
            <span class="hint">@settings.Hint</span>
        }
    </div>
</div>

<style asp-src="~/OrchardCore.ContentFields/Scripts/date-field-localized/date-field-localized.css" at="Head"></style>
<script asp-src="~/OrchardCore.ContentFields/Scripts/date-field-localized/date-field-localized.min.js" debug-src="~/OrchardCore.ContentFields/Scripts/date-field-localized/date-field-localized.js" at="Foot"></script>
<script at="Foot">
    initDateFieldLocalized('@datepickerId', '@language', '@shortDatePattern');
</script>
