@model OrchardCore.ContentFields.ViewModels.EditTextFieldViewModel
@using OrchardCore.Mvc.Utilities
@using OrchardCore.Localization.Data
@using OrchardCore.ContentManagement.Metadata.Models
@inject IDataLocalizer D
@{
    var settings = Model.PartFieldDefinition.GetSettings<TextFieldSettings>();
    string localizedFieldName = D[Model.PartFieldDefinition.DisplayName(), $"Content Fields{Constants.ContextSeparator}{Model.PartFieldDefinition.PartDefinition.Name}"];
    var isAdvanced = Model.PartFieldDefinition.DisplayMode() == "Advanced";
}

@if (settings.Type == FieldBehaviorType.GeneratedHidden)
{
    <input type="hidden" asp-for="Text" />

    return;
}

<div class="@Orchard.GetFieldWrapperClasses(Model.PartFieldDefinition)" id="@Html.IdFor(x => x.Text)_FieldWrapper">
    <label asp-for="Text" class="@Orchard.GetLabelClasses(inputRequired: settings.Required)">@localizedFieldName</label>
    <div class="@Orchard.GetEndClasses()">
        @if (isAdvanced)
        {
            @await DisplayAsync(await New.PhoneInput(Value: Model.Text, InputName: Html.NameFor(m => m.Text), Disabled: settings.Type == FieldBehaviorType.GeneratedDisabled))
        }
        else
        {
            <input asp-for="Text" class="form-control content-preview-text" type="tel" placeholder="@settings.Placeholder" asp-is-disabled="settings.Type == FieldBehaviorType.GeneratedDisabled" />
        }
        <span asp-validation-for="Text"></span>
        @if (!string.IsNullOrEmpty(settings.Hint))
        {
            <span class="hint">@settings.Hint</span>
        }
    </div>
</div>
