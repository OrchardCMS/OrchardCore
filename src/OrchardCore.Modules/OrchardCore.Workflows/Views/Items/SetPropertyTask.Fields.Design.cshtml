@using OrchardCore.Workflows.Models
@model ActivityViewModel<SetPropertyTask>

@{
    var expression = Model.Activity.Syntax == WorkflowScriptSyntax.Liquid
        ? Model.Activity.LiquidValue?.Expression
        : Model.Activity.Value?.Expression;
}

<header>
    <h4><i class="fa-solid fa-pencil" aria-hidden="true"></i>@Model.Activity.GetTitleOrDefault(() => T["Set {0} Property", Model.Activity.PropertyName])</h4>
</header>
<span><em>@expression</em></span>
