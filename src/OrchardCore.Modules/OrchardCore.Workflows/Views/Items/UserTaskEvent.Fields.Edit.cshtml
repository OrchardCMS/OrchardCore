@using OrchardCore.Workflows.UserTasks.ViewModels
@model UserTaskEventViewModel

<div class="ocat-wrapper" asp-validation-class-for="Actions">
    <label asp-for="Actions" class="ocat-label">@T["Actions"]</label>
    <div class="ocat-end">
        <input asp-for="Actions" class="form-control" />
        <span asp-validation-for="Actions"></span>
        <span class="hint">@T["Enter one or more comma-separated action names."]</span>
    </div>
</div>

<div class="ocat-wrapper" asp-validation-class-for="Roles">
    <label asp-for="Roles" class="ocat-label">@T["Roles"]</label>
    <div class="ocat-end">
        @await Component.InvokeAsync("SelectRoles", new { selectedRoles = Model.Roles, htmlName = Html.NameFor(m => m.Roles) })
        <span asp-validation-for="Roles"></span>
        <span class="hint">@T["Select the roles that are allowed to perform the specified actions. If no roles are selected, then any role is allowed."]</span>
    </div>
</div>
