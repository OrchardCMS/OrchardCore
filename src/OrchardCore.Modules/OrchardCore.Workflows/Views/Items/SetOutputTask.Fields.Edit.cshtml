@using OrchardCore.Workflows.ViewModels
@model SetOutputTaskViewModel

<div class="@Orchard.GetWrapperClasses()" asp-validation-class-for="OutputName">
    <label asp-for="OutputName" class="@Orchard.GetLabelClasses()">@T["Name"]</label>
    <div class="@Orchard.GetEndClasses()">
        <input asp-for="OutputName" class="form-control" autofocus="autofocus" />
        <span asp-validation-for="OutputName"></span>
        <span class="hint">@T["The name to output to."]</span>
    </div>
</div>

<div class="@Orchard.GetWrapperClasses()" asp-validation-class-for="Value">
    <label asp-for="Value" class="@Orchard.GetLabelClasses()">@T["Value"]</label>
    <div class="@Orchard.GetEndClasses()">
        <input type="text" asp-for="Value" class="form-control code" />
        <span asp-validation-for="Value"></span>
        <span class="hint">@T["The value to store in the specified output variable. With JavaScript support."]</span>
    </div>
</div>
