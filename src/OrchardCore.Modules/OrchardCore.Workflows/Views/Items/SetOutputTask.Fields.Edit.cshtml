@using OrchardCore.Workflows.Models
@using OrchardCore.Workflows.ViewModels
@model SetOutputTaskViewModel

<div class="ocat-wrapper" asp-validation-class-for="OutputName">
    <label asp-for="OutputName" class="ocat-label">@T["Name"]</label>
    <div class="ocat-end">
        <input asp-for="OutputName" class="form-control" autofocus="autofocus" />
        <span asp-validation-for="OutputName"></span>
        <span class="hint">@T["The name to output to."]</span>
    </div>
</div>

<div class="ocat-wrapper" asp-validation-class-for="Syntax">
    <label asp-for="Syntax" class="ocat-label">@T["Syntax"]</label>
    <div class="ocat-end">
        <select asp-for="Syntax" class="form-select">
            <option value="@nameof(WorkflowScriptSyntax.JavaScript)">@T["JavaScript"]</option>
            <option value="@nameof(WorkflowScriptSyntax.Liquid)">@T["Liquid"]</option>
        </select>
        <span asp-validation-for="Syntax"></span>
    </div>
</div>

<div id="@(Html.IdFor(m => m.Value))_group" class="ocat-wrapper @(Model.Syntax == WorkflowScriptSyntax.JavaScript ? "" : "d-none")" asp-validation-class-for="Value">
    <label asp-for="Value" class="ocat-label">@T["Value"]</label>
    <div class="ocat-end">
        <input type="text" asp-for="Value" class="form-control code" />
        <span asp-validation-for="Value"></span>
        <span class="hint">@T["The JavaScript value to store in the specified output variable."]</span>
    </div>
</div>

<div id="@(Html.IdFor(m => m.LiquidValue))_group" class="ocat-wrapper @(Model.Syntax == WorkflowScriptSyntax.Liquid ? "" : "d-none")" asp-validation-class-for="LiquidValue">
    <label asp-for="LiquidValue" class="ocat-label">@T["Value"]</label>
    <div class="ocat-end">
        <input type="text" asp-for="LiquidValue" class="form-control code" />
        <span asp-validation-for="LiquidValue"></span>
        <span class="hint">@T["The Liquid value to store in the specified output variable."]</span>
    </div>
</div>

<script at="Foot" type="module">
    const syntaxElement = document.getElementById('@Html.IdFor(m => m.Syntax)');
    const javaScriptGroup = document.getElementById('@($"{Html.IdFor(m => m.Value)}_group")');
    const liquidGroup = document.getElementById('@($"{Html.IdFor(m => m.LiquidValue)}_group")');

    const toggleEditors = () => {
        const useLiquid = syntaxElement.value === '@nameof(WorkflowScriptSyntax.Liquid)';
        javaScriptGroup.classList.toggle('d-none', useLiquid);
        liquidGroup.classList.toggle('d-none', !useLiquid);
    };

    syntaxElement.addEventListener('change', toggleEditors);
    toggleEditors();
</script>
