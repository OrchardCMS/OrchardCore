@using OrchardCore.Workflows.ViewModels
@model WhileLoopTaskViewModel

<div class="@Orchard.GetWrapperClasses()" asp-validation-class-for="ConditionExpression">
    <label asp-for="ConditionExpression" class="@Orchard.GetLabelClasses()">@T["Condition Expression"]</label>
    <div class="@Orchard.GetEndClasses()">
        <input type="text" asp-for="ConditionExpression" class="form-control code" autofocus />
        <span asp-validation-for="ConditionExpression"></span>
        <span class="hint">@T["A JavaScript script expression that evaluates to true or false."]</span>
    </div>
</div>
