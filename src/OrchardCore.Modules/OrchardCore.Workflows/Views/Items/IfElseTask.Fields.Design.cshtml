@using OrchardCore.Workflows.Models
@model ActivityViewModel<IfElseTask>

@{
    var expression = Model.Activity.Syntax == WorkflowScriptSyntax.Liquid
        ? Model.Activity.LiquidCondition?.Expression
        : Model.Activity.Condition?.Expression;
}

<header>
    <h4><i class="fa-solid fa-diamond" aria-hidden="true"></i>@Model.Activity.GetTitleOrDefault(() => T["If/Else"])</h4>
</header>
<span>@T["Evaluate <em>{0}</em>", expression]</span>
