@using OrchardCore.Workflows.Models
@using OrchardCore.Workflows.ViewModels
@model ForLoopTaskViewModel

<div class="mb-3" asp-validation-class-for="Syntax">
    <label asp-for="Syntax" class="form-label">@T["Syntax"]</label>
    <select asp-for="Syntax" class="form-select">
        <option value="@nameof(WorkflowScriptSyntax.JavaScript)">@T["JavaScript"]</option>
        <option value="@nameof(WorkflowScriptSyntax.Liquid)">@T["Liquid"]</option>
    </select>
    <span asp-validation-for="Syntax"></span>
</div>

<div id="@(Html.IdFor(m => m.FromExpression))_group" class="mb-3 @(Model.Syntax == WorkflowScriptSyntax.JavaScript ? "" : "d-none")" asp-validation-class-for="FromExpression">
    <label asp-for="FromExpression" class="form-label">@T["From Expression"]</label>
    <input type="text" asp-for="FromExpression" class="form-control code" />
    <span asp-validation-for="FromExpression"></span>
    <span class="hint">@T["The JavaScript start value. Example: {0}", "0"]</span>
</div>

<div id="@(Html.IdFor(m => m.LiquidFromExpression))_group" class="mb-3 @(Model.Syntax == WorkflowScriptSyntax.Liquid ? "" : "d-none")" asp-validation-class-for="LiquidFromExpression">
    <label asp-for="LiquidFromExpression" class="form-label">@T["From Expression"]</label>
    <input type="text" asp-for="LiquidFromExpression" class="form-control code" />
    <span asp-validation-for="LiquidFromExpression"></span>
    <span class="hint">@T["The Liquid start value. Example: {0}", "{{ Workflow.Properties.Start }}"]</span>
</div>

<div id="@(Html.IdFor(m => m.ToExpression))_group" class="mb-3 @(Model.Syntax == WorkflowScriptSyntax.JavaScript ? "" : "d-none")" asp-validation-class-for="ToExpression">
    <label asp-for="ToExpression" class="form-label">@T["To Expression"]</label>
    <input type="text" asp-for="ToExpression" class="form-control code" />
    <span asp-validation-for="ToExpression"></span>
    <span class="hint">@T["The JavaScript end value. Example: {0}", "10"]</span>
</div>

<div id="@(Html.IdFor(m => m.LiquidToExpression))_group" class="mb-3 @(Model.Syntax == WorkflowScriptSyntax.Liquid ? "" : "d-none")" asp-validation-class-for="LiquidToExpression">
    <label asp-for="LiquidToExpression" class="form-label">@T["To Expression"]</label>
    <input type="text" asp-for="LiquidToExpression" class="form-control code" />
    <span asp-validation-for="LiquidToExpression"></span>
    <span class="hint">@T["The Liquid end value. Example: {0}", "{{ Workflow.Properties.End }}"]</span>
</div>

<div id="@(Html.IdFor(m => m.StepExpression))_group" class="mb-3 @(Model.Syntax == WorkflowScriptSyntax.JavaScript ? "" : "d-none")" asp-validation-class-for="StepExpression">
    <label asp-for="StepExpression" class="form-label">@T["Step Expression"]</label>
    <input type="text" asp-for="StepExpression" class="form-control code" />
    <span asp-validation-for="StepExpression"></span>
    <span class="hint">@T["The JavaScript step value. Example: {0}", "1"]</span>
</div>

<div id="@(Html.IdFor(m => m.LiquidStepExpression))_group" class="mb-3 @(Model.Syntax == WorkflowScriptSyntax.Liquid ? "" : "d-none")" asp-validation-class-for="LiquidStepExpression">
    <label asp-for="LiquidStepExpression" class="form-label">@T["Step Expression"]</label>
    <input type="text" asp-for="LiquidStepExpression" class="form-control code" />
    <span asp-validation-for="LiquidStepExpression"></span>
    <span class="hint">@T["The Liquid step value. Example: {0}", "{{ Workflow.Properties.Step }}"]</span>
</div>

<div class="mb-3" asp-validation-class-for="LoopVariableName">
    <label asp-for="LoopVariableName" class="form-label">@T["Looping Variable"]</label>
    <input type="text" asp-for="LoopVariableName" class="form-control" />
    <span asp-validation-for="LoopVariableName"></span>
    <span class="hint">@T["The name of the looping variable. The current value of each iteration is set to a property with this name as well as the last result."]</span>
</div>

<script at="Foot">
    document.addEventListener('DOMContentLoaded', () => {
        const syntaxElement = document.getElementById('@Html.IdFor(m => m.Syntax)');
        const javaScriptGroups = [
            document.getElementById('@($"{Html.IdFor(m => m.FromExpression)}_group")'),
            document.getElementById('@($"{Html.IdFor(m => m.ToExpression)}_group")'),
            document.getElementById('@($"{Html.IdFor(m => m.StepExpression)}_group")')
        ];
        const liquidGroups = [
            document.getElementById('@($"{Html.IdFor(m => m.LiquidFromExpression)}_group")'),
            document.getElementById('@($"{Html.IdFor(m => m.LiquidToExpression)}_group")'),
            document.getElementById('@($"{Html.IdFor(m => m.LiquidStepExpression)}_group")')
        ];

        const toggleEditors = () => {
            const useLiquid = syntaxElement.value === '@nameof(WorkflowScriptSyntax.Liquid)';

            for (const group of javaScriptGroups) {
                group.classList.toggle('d-none', useLiquid);
            }

            for (const group of liquidGroups) {
                group.classList.toggle('d-none', !useLiquid);
            }
        };

        syntaxElement.addEventListener('change', toggleEditors);
        toggleEditors();
    });
</script>
