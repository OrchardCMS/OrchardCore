@using OrchardCore.Workflows.Models
@model ActivityViewModel<ForEachTask>

@{
    var expression = Model.Activity.Syntax == WorkflowScriptSyntax.Liquid
        ? Model.Activity.LiquidEnumerable?.Expression
        : Model.Activity.Enumerable?.Expression;
}

<header>
    <h4><i class="fa-solid fa-circle-notch" aria-hidden="true"></i>@Model.Activity.GetTitleOrDefault(() => T["For Each"])</h4>
</header>
<span>@T["Iterate <em>{0}</em> over <em>{1}</em>", Model.Activity.LoopVariableName, expression]</span>
