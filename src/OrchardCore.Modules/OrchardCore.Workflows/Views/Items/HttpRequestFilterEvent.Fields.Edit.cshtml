@using OrchardCore.Workflows.Http.ViewModels
@model HttpRequestFilterEventViewModel

<div class="ocat-wrapper" asp-validation-class-for="HttpMethod">
    <label asp-for="HttpMethod" class="ocat-label">@T["HTTP Method"]</label>
    <div class="ocat-end">
        <select asp-for="HttpMethod" class="form-select" asp-items="Model.AvailableHttpMethods"></select>
        <span asp-validation-for="HttpMethod"></span>
        <span class="hint">@T["The HTTP method to match."]</span>
    </div>
</div>

<div class="ocat-wrapper" asp-validation-class-for="ControllerName">
    <label asp-for="ControllerName" class="ocat-label">@T["Controller"]</label>
    <div class="ocat-end">
        <input asp-for="ControllerName" type="text" class="form-control" />
        <span asp-validation-for="ControllerName"></span>
        <span class="hint">@T["The controller name to match."]</span>
    </div>
</div>

<div class="ocat-wrapper" asp-validation-class-for="ActionName">
    <label asp-for="ActionName" class="ocat-label">@T["Action"]</label>
    <div class="ocat-end">
        <input asp-for="ActionName" type="text" class="form-control" />
        <span asp-validation-for="ActionName"></span>
        <span class="hint">@T["The action name to match."]</span>
    </div>
</div>

<div class="ocat-wrapper" asp-validation-class-for="AreaName">
    <label asp-for="AreaName" class="ocat-label">@T["Area"]</label>
    <div class="ocat-end">
        <input asp-for="AreaName" type="text" class="form-control" />
        <span asp-validation-for="AreaName"></span>
        <span class="hint">@T["The area name to match."]</span>
    </div>
</div>
