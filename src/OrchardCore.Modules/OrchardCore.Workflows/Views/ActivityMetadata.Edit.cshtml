@using OrchardCore.Workflows.ViewModels
@model ActivityMetadataEditViewModel

<div class="ocat-wrapper" asp-validation-class-for="Title">
    <label asp-for="Title" class="ocat-label">@T["Title"]</label>
    <div class="ocat-end">
        <input type="text" asp-for="Title" class="form-control" />
        <span asp-validation-for="Title"></span>
        <span class="hint">@T["Optionally provide a custom title for this activity."]</span>
    </div>
</div>
