@model ContentItem
@using Microsoft.AspNetCore.Html
@using OrchardCore.ContentManagement
@using OrchardCore.Demo.Models

@(Model.TryGet<TestContentPartA>(out var testContentPart) ? testContentPart.Line : string.Empty)

@{
    await ThemeLayout.Zones["Footer"].AddAsync("In the footer", "2.0");
    await ThemeLayout.Zones["Footer"].AddAsync("Before", "before");
    await ThemeLayout.Zones["Footer"].AddAsync(new HtmlString("AFTER"), "after");
}
