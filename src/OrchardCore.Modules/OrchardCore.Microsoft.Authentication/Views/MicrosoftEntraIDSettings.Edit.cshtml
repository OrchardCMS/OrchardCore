@using OrchardCore
@using OrchardCore.Microsoft.Authentication.ViewModels
@model AzureADSettingsViewModel

<div class="@Orchard.GetWrapperClasses()">
    <div class="@Orchard.GetEndClasses(true)">
        <p class="alert alert-warning" role="alert">
            @T["The website might be restarted upon saving the settings, potentially leading to temporary unresponsiveness during the process."]
            <a class="seedoc" href="@(OrchardCore.Admin.Constants.DocsUrl)reference/modules/Microsoft.Authentication/#azure-active-directory" target="_blank">@T["See documentation"]</a>
        </p>
    </div>
</div>

<div class="@Orchard.GetWrapperClasses()">
    <div class="@Orchard.GetEndClasses(true)">
        <h3>@T["Microsoft Entra ID Authentication Settings"]</h3>
    </div>
</div>

<div class="@Orchard.GetWrapperClasses()" asp-validation-class-for="DisplayName">
    <label asp-for="DisplayName" class="@Orchard.GetLabelClasses()">@T["Display Name"]</label>
    <div class="@Orchard.GetEndClasses()">
        <input asp-for="DisplayName" class="form-control" />
        <span asp-validation-for="DisplayName"></span>
        <span class="hint">@T["The display name of the provider."]</span>
    </div>
</div>

<div class="@Orchard.GetWrapperClasses()" asp-validation-class-for="AppId">
    <label asp-for="AppId" class="@Orchard.GetLabelClasses()">@T["AppId"]</label>
    <div class="@Orchard.GetEndClasses()">
        <input asp-for="AppId" class="form-control" />
        <span asp-validation-for="AppId"></span>
        <span class="hint">@T["The Application ID found on the Microsoft Entra ID App registration parameters."]</span>
    </div>
</div>

<div class="@Orchard.GetWrapperClasses()" asp-validation-class-for="TenantId">
    <label asp-for="TenantId" class="@Orchard.GetLabelClasses()">@T["TenantId"]</label>
    <div class="@Orchard.GetEndClasses()">
        <input asp-for="TenantId" class="form-control" />
        <span asp-validation-for="TenantId"></span>
        <span class="hint">@T["The Tenant (Directory) ID found on the Microsoft Entra ID App registration parameters. For multi-tenant App registrations, use 'common' or 'organizations'."]</span>
    </div>
</div>

<div class="@Orchard.GetWrapperClasses()" asp-validation-class-for="CallbackPath">
    <label asp-for="CallbackPath" class="@Orchard.GetLabelClasses()">@T["CallbackPath"]</label>
    <div class="@Orchard.GetEndClasses()">
        <input asp-for="CallbackPath" class="form-control" placeholder="/signin-oidc" />
        <span asp-validation-for="CallbackPath"></span>
        <span class="hint">@T["The request path within the application's base path where the user-agent will be returned. The middleware will process this request when it arrives."]</span>
    </div>
</div>

<div class="@Orchard.GetWrapperClasses()" asp-validation-class-for="SaveTokens">
    <div class="@Orchard.GetEndClasses(true)">
        <div class="form-check">
            <input type="checkbox" class="form-check-input" asp-for="SaveTokens">
            <label class="form-check-label" asp-for="SaveTokens">@T["Store tokens"]</label>
            <span class="hint dashed">@T["Store external authentication tokens for reuse"]</span>
        </div>
    </div>
</div>
