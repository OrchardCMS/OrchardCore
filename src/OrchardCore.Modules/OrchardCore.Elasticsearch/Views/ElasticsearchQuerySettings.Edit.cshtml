@using OrchardCore.Elasticsearch
@model ElasticsearchDefaultQueryViewModel

<div class="ocat-wrapper">
    <div class="ocat-end-offset">
        <h4 class="mt-4 mb-0">@T["Default Query Settings"]</h4>
    </div>
</div>
<div class="ocat-wrapper" asp-validation-class-for="QueryAnalyzerName">
    <label asp-for="QueryAnalyzerName" class="ocat-label">@T["Query analyzer"]</label>
    <div class="ocat-end">
    <select asp-for="QueryAnalyzerName" asp-items="Model.Analyzers" class="form-select"></select>
    <span asp-validation-for="QueryAnalyzerName" class="text-danger"></span>
    </div>
</div>

<div class="ocat-wrapper" asp-validation-class-for="SearchType">
    <label asp-for="SearchType" class="ocat-label">@T["Search type"]</label>
    <div class="ocat-end">
    <select asp-for="SearchType" class="form-select" asp-items="Model.SearchTypes" data-raw-type="@ElasticsearchConstants.CustomSearchType"></select>
    <span asp-validation-for="SearchType"></span>
    </div>
</div>

<div class="ocat-wrapper" asp-validation-class-for="DefaultQuery" id="DefaultQueryContainer">
    <label asp-for="DefaultQuery" class="ocat-label">@T["Query"]</label>
    <div class="ocat-end">
    <textarea asp-for="DefaultQuery" class="form-control" rows="10"></textarea>
    <span asp-validation-for="DefaultQuery"></span>
    <span class="hint">@T["Create a custom Elasticsearch query to be utilized for each search request. Liquid is supported, so use the <code>{0}</code> template as a substitute for the user-provided search term.", "{{ term }}"]</span>
    </div>
</div>

<div class="ocat-wrapper" asp-validation-class-for="DefaultSearchFields" id="DefaultQueryFields">
    <label asp-for="DefaultSearchFields" class="ocat-label">@T["Query field names"]</label>
    <div class="ocat-end">
    <div>
        <ul class="list-group">
            @for (int i = 0; i < Model.DefaultSearchFields.Length; i++)
            {
                var option = Model.DefaultSearchFields[i];
                <li class="list-group-item">
                    <div class="form-check">
                        <label class="form-check-label">
                            <input class="form-check-input"
                                   type="checkbox"
                                   name="@Html.NameFor(m => m.DefaultSearchFields[i].Selected)"
                                   value="true"
                                   @(option.Selected ? "checked" : string.Empty) />
                            <input type="hidden" name="@Html.NameFor(m => m.DefaultSearchFields[i].Text)" value="@option.Text" />
                            <input type="hidden" name="@Html.NameFor(m => m.DefaultSearchFields[i].Value)" value="@option.Value" />
                            @option.Text
                        </label>
                    </div>
                </li>
            }
        </ul>
        <span class="hint">@T["The fields to use for query. Leave it blank to query all searchable fields."]</span>
    </div>
    </div>
</div>

<script asp-src="~/OrchardCore.Elasticsearch/Scripts/elasticsearch-query-settings/elasticsearch-query-settings.min.js" debug-src="~/OrchardCore.Elasticsearch/Scripts/elasticsearch-query-settings/elasticsearch-query-settings.js" at="Foot" type="module"></script>
