@model ElasticContentIndexSettingsViewModel

<h4>@T["Elasticsearch Index settings"]</h4>

<div class="@Orchard.GetWrapperClasses()">
    <div class="@Orchard.GetEndClasses(true)">
        <div class="form-check">
            <input type="checkbox" class="form-check-input" asp-for="ElasticContentIndexSettings.Included" checked="@Model.ElasticContentIndexSettings.Included" />
            <label class="form-check-label" asp-for="ElasticContentIndexSettings.Included">@T["Include this element in the index"]</label>
            <span class="hint dashed">@T["Check to include the value of this element in the index."]</span>
        </div>
    </div>
</div>
