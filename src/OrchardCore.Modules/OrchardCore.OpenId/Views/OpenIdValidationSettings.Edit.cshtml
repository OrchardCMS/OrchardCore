@using OrchardCore.OpenId.ViewModels
@model OpenIdValidationSettingsViewModel

<div class="ocat-wrapper">
    <div class="ocat-end-offset">
        <p class="alert alert-warning">
            @T["To be able to validate tokens issued by a separate tenant, " +
                    "you must register a custom scope in the server options " +
                    "of the tenant hosting the authorization server."]
        </p>
    </div>
</div>

<div class="ocat-wrapper" asp-validation-class-for="Tenant">
    <label asp-for="Tenant" class="ocat-label">@T["Authorization server tenant"]</label>
    <div class="ocat-end">
        <input asp-for="Tenant" class="form-control" />
        <span asp-validation-for="Tenant"></span>
    </div>
</div>

<div id="AuthorityField" class="ocat-wrapper" asp-validation-class-for="Authority">
    <label asp-for="Authority" class="ocat-label">@T["Authority"]</label>
    <div class="ocat-end">
        <input asp-for="Authority" class="form-control" />
        <span asp-validation-for="Authority"></span>
        <span class="hint">@T["The URL of the remote OpenID Connect server. Using HTTPS is highly recommended for security."]</span>
    </div>
</div>

<div class="ocat-wrapper" asp-validation-class-for="MetadataAddress">
    <label asp-for="MetadataAddress" class="ocat-label">@T["OpenID Connect Metadata Address"]</label>
    <div class="ocat-end">
        <input asp-for="MetadataAddress" class="form-control" />
        <span asp-validation-for="MetadataAddress"></span>
        <span class="hint">@T["The well-formed URI for the OpenID Connect Metadata Address endpoint. This is intended for advanced scenarios where metadata is not available from the standard authority endpoint. Note: This option cannot be used with a Tenant configuration, and HTTPS is strongly recommended."]</span>
    </div>
</div>

<div id="AudienceField" class="ocat-wrapper" asp-validation-class-for="Audience">
    <label asp-for="Audience" class="ocat-label">@T["Audience"]</label>
    <div class="ocat-end">
        <input asp-for="Audience" class="form-control" />
        <span asp-validation-for="Audience"></span>
        <span class="hint">@T["The unique name associated with this tenant. If not specified, the tenant name will be used as the default audience."]</span>
    </div>
</div>

<div id="DisableTokenTypeValidationField" class="ocat-wrapper" asp-validation-class-for="DisableTokenTypeValidation">
    <div class="ocat-end-offset">
        <div class="form-check">
            <input type="checkbox" class="form-check-input" asp-for="DisableTokenTypeValidation">
            <label class="form-check-label" asp-for="DisableTokenTypeValidation">@T["Disable token type validation"]</label>
            <span class="hint dashed">@T["Token type validation can be disabled to accept JWT tokens from servers that do not support the '{0}' type header.", "at+jwt"]</span>
        </div>
    </div>
</div>

<script at="Foot">
    document.addEventListener('DOMContentLoaded', function () {
        var authority = document.getElementById('@Html.IdFor(model => model.Authority)');
        var audience = document.getElementById('@Html.IdFor(model => model.Audience)');
        var tenant = document.getElementById('@Html.IdFor(model => model.Tenant)');
        var disableTokenTypeValidation = document.getElementById('@Html.IdFor(model => model.DisableTokenTypeValidation)');
        var authorityField = document.getElementById('AuthorityField');
        var audienceField = document.getElementById('AudienceField');
        var disableTokenTypeValidationField = document.getElementById('DisableTokenTypeValidationField');

        tenant.addEventListener('change', function () {
            if (tenant.value != '') {
                authority.value = null;
                authorityField.style.display = 'none';
                audience.value = null;
                audienceField.style.display = 'none';
                disableTokenTypeValidation.value = false;
                disableTokenTypeValidationField.style.display = 'none';
            }
            else {
                authorityField.style.display = '';
                audienceField.style.display = '';
                disableTokenTypeValidationField.style.display = '';
            }
        });

        tenant.dispatchEvent(new Event('change'));
    });
</script>
