@model dynamic

<zone Name="Title"><h1>@RenderTitleSegments(T["Configure OpenID Connect validation settings"])</h1></zone>

<form asp-action="Index" method="post" class="no-multisubmit">
    @Html.ValidationSummary()
    @await DisplayAsync(Model.Content)

    <div class="@Orchard.GetWrapperClasses()">
        <div class="@Orchard.GetEndClasses(true)">
            <button class="btn btn-primary" type="submit">@T["Update the server settings and reload the tenant"]</button>
        </div>
    </div>
</form>
