@model OrchardCore.Users.ViewModels.EditPasswordViewModel

<zone Name="Title"><h1>@RenderTitleSegments(T["Change Password"])</h1></zone>

<form asp-controller="Admin" asp-action="EditPassword" method="post" class="form-horizontal no-multisubmit">
    <div asp-validation-summary="All"></div>
    <input asp-for="UsernameOrEmail" type="hidden" />
    @if (Model.UsernameOrEmail == User.Identity.Name)
    {
        <div class="@Orchard.GetWrapperClasses()">
            <label asp-for="CurrentPassword" class="@Orchard.GetLabelClasses(false, "w-lg-75", "w-xl-50")">@T["Current password"]</label>
            <div class="@Orchard.GetEndClasses("w-lg-75", "w-xl-50")">
                <input asp-for="CurrentPassword" class="form-control" autofocus />
                <span asp-validation-for="CurrentPassword" class="text-danger"></span>
                <span class="text-muted form-text small">@T["To confirm the change, please provide your password."]</span>
            </div>
        </div>
    }
    <div class="@Orchard.GetWrapperClasses()">
        <label asp-for="NewPassword" class="@Orchard.GetLabelClasses(false, "w-lg-75", "w-xl-50")">@T["New password"]</label>
        <div class="@Orchard.GetEndClasses("w-lg-75", "w-xl-50")">
            <input asp-for="NewPassword" class="form-control" />
            <div id="passwordStrength"></div>
            <span asp-validation-for="NewPassword" class="text-danger"></span>
        </div>
    </div>
    <div class="@Orchard.GetWrapperClasses()">
        <label asp-for="PasswordConfirmation" class="@Orchard.GetLabelClasses(false, "w-lg-75", "w-xl-50")">@T["New password confirmation"]</label>
        <div class="@Orchard.GetEndClasses("w-lg-75", "w-xl-50")">
            <input asp-for="PasswordConfirmation" class="form-control" />
            <span asp-validation-for="PasswordConfirmation" class="text-danger"></span>
        </div>
    </div>
    <div class="@Orchard.GetWrapperClasses()">
        <div class="@Orchard.GetEndClasses(true, "w-lg-75", "w-xl-50")">
            <button class="btn btn-primary submit" type="submit">@T["Submit"]</button>
            <a class="btn btn-secondary cancel" role="button" asp-route-action="Index">@T["Cancel"]</a>
        </div>
    </div>
</form>
