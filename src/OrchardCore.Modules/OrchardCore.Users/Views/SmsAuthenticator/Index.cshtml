@using OrchardCore.Users.Services

@model RequestCodeSmsAuthenticatorViewModel

@{
    ViewLayout = "Layout__TwoFactor";
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-action="Index" asp-controller="TwoFactorAuthentication">@T["Two-Factor Authentication"]</a></li>
        <li class="breadcrumb-item active" aria-current="page">@RenderTitleSegments(T["Configure SMS Authenticator"])</li>
    </ol>
</nav>

<div class="alert alert-info">
    @T["To utilize SMS as a two-factor authentication method, please click the 'Request Code' button below in order to confirm your Phone number."]
</div>

<form method="post">
    <div class="mb-3">
        <label asp-for="PhoneNumber" class="form-label">@T["Phone Number"]</label>
        @await DisplayAsync(await New.PhoneInput(Value: Model.PhoneNumber, InputName: Html.NameFor(m => m.PhoneNumber), Disabled: !Model.AllowChangingPhoneNumber))
    </div>
    <button type="submit" class="btn btn-primary">@T["Request Code"]</button>
</form>
