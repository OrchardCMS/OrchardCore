@model OrchardCore.Users.ViewModels.EditUserEmailViewModel

<div class="@Orchard.GetWrapperClasses()" asp-validation-class-for="Email">
    <label asp-for="Email" class="@Orchard.GetLabelClasses()">@T["Email"]</label>
    <div class="@Orchard.GetEndClasses()">
        <div class="input-group col-md-4">
            <span class="input-group-text"><i class="fa-solid fa-envelope" aria-hidden="true"></i></span>
            <input asp-for="Email" class="form-control" type="email" asp-is-disabled="@(!Model.AllowEditing)" />
            <span asp-validation-for="Email" class="text-danger"></span>
        </div>
    </div>
</div>
