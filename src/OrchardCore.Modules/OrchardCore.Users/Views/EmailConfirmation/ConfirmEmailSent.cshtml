@{
    ViewLayout = "Layout__Login";
    var returnUrl = Context.Request.Query["ReturnUrl"];
    var resendCode = Context.Request.Query["code"];
}

<h2>@T["Email confirmation sent"]</h2>
<div>
    <p>
        @T["An email has been sent to you. Please click on the link it contains in order to have access on this site."]
    </p>
    @if (!string.IsNullOrWhiteSpace(resendCode))
    {
        <form id="resend-email-confirmation-form" asp-controller="Account" asp-action="ResendEmailConfirmation" asp-area="@UserConstants.Features.Users"
              asp-route-returnurl="@returnUrl" method="post" class="mb-3 no-multisubmit">
            <input name="code" type="hidden" value="@resendCode" />
            <a href="#" onclick="event.preventDefault(); document.getElementById('resend-email-confirmation-form').submit();">@T["Send confirmation email"]</a>
        </form>
    }

    <p>
        @if (!string.IsNullOrWhiteSpace(returnUrl) && Url.IsLocalUrl(returnUrl))
        {
            <a href="@returnUrl">@T["Previous Page"]</a>
        }
        else
        {
            <a href="@Url.Content("~/")">@T["Home"]</a>
        }
    </p>
</div>
