@using OrchardCore.Users.Handlers
@model OrchardCore.Users.Models.ExternalLoginSettings

<div class="ocat-wrapper">
    <div class="ocat-end-offset">
        <h5>@T["Configuring External Authentication for User Login with Third-Party Providers"]</h5>
    </div>
</div>

<div class="ocat-wrapper" asp-validation-class-for="UseExternalProviderIfOnlyOneDefined">
    <div class="ocat-end-offset">
        <div class="form-check">
            <input type="checkbox" class="form-check-input" asp-for="UseExternalProviderIfOnlyOneDefined" />
            <span asp-validation-for="UseExternalProviderIfOnlyOneDefined"></span>
            <label class="form-check-label" asp-for="UseExternalProviderIfOnlyOneDefined">@T["Use external provider for login."]</label>
            <span class="hint dashed">@T["If only one external provider is defined, auto challenge the provider to login. You should also configure registration options"]</span>
        </div>
    </div>
</div>

<div class="ocat-wrapper" asp-validation-class-for="UseScriptToSyncProperties">
    <div class="ocat-end-offset">
        <div class="form-check">
            <input type="checkbox" class="form-check-input external-login-use-script" asp-for="UseScriptToSyncProperties" />
            <span asp-validation-for="UseScriptToSyncProperties"></span>
            <label class="form-check-label" asp-for="UseScriptToSyncProperties">@T["Use a script to set user roles, user claims and user properties based on external provider claims"]</label>
            <span class="hint dashed">
                @T["If selected, none of the implemented {0}, if any, will be triggered.", nameof(IExternalLoginEventHandler)]
            </span>
        </div>
    </div>
</div>

<div class="ocat-wrapper" id="doc_editor_wrapper">
    <div class="ocat-end-offset">
        <div class="form-control" id="doc_editor" asp-for="Text" style="min-height: 500px;max-width:750px"></div>
    </div>
</div>

<div class="ocat-wrapper" asp-validation-class-for="SyncPropertiesScript" id="SyncRolesScript_wrapper">
    <div class="ocat-end-offset">
        <button type="button" class="btn btn-secondary mb-2" onclick="resetScript()">@T["Reset Script"]</button>
        <div id="@Html.IdFor(x => x.SyncPropertiesScript)_editor" asp-for="Text" style="min-height: 400px;" class="form-control external-login-script-editor"></div>
        <textarea asp-for="SyncPropertiesScript" hidden class="external-login-script-value">@Html.Raw(Model.SyncPropertiesScript)</textarea>
    </div>
</div>

<style asp-name="monaco"></style>
<script asp-name="monaco" at="Foot"></script>
<script asp-src="~/OrchardCore.Users/Scripts/user-editors/external-login-settings.min.js" debug-src="~/OrchardCore.Users/Scripts/user-editors/external-login-settings.js" depends-on="monaco" at="Foot" type="module"></script>
