@model OrchardCore.Users.ViewModels.RoleLoginSettingsViewModel

<div class="@Orchard.GetWrapperClasses()" asp-validation-class-for="RequireTwoFactorAuthenticationForSpecificRoles">
    <div class="@Orchard.GetEndClasses(true)">
        <div class="form-check">
            <input type="checkbox" class="form-check-input" asp-for="RequireTwoFactorAuthenticationForSpecificRoles" data-bs-toggle="collapse" data-bs-target="#rolesContainer" aria-expanded="false" aria-controls="rolesContainer" />
            <span asp-validation-for="RequireTwoFactorAuthenticationForSpecificRoles"></span>
            <label class="form-check-label" asp-for="RequireTwoFactorAuthenticationForSpecificRoles">@T["Require two-factor authentication specific roles"]</label>
        </div>
    </div>
</div>

<div class="@Orchard.GetWrapperClasses("collapse" + (Model.RequireTwoFactorAuthenticationForSpecificRoles ? " show" : string.Empty))" asp-validation-class-for="Roles" id="rolesContainer">
    <div class="@Orchard.GetEndClasses(true, "ps-3")">
        <span class="hint">@T["Select the roles to require two-factor authentication for."]</span>

        @for (var i = 0; i < Model.Roles.Length; i++)
        {
            <div class="form-check">
                <input asp-for="Roles[i].IsSelected" type="checkbox" class="form-check-input">
                <input type="hidden" asp-for="Roles[i].Role" />
                <label class="form-check-label cursor-pointer" asp-for="Roles[i].IsSelected">@Model.Roles[i].Role</label>
            </div>
        }
    </div>
</div>
