@model CustomUserSettingsDeploymentStepViewModel

<div class="ocat-wrapper">
    <div class="ocat-end-offset">
        <h5>@T["Custom User Settings"]</h5>
    </div>
</div>

<div class="ocat-wrapper" asp-validation-class-for="IncludeAll">
    <div class="ocat-end-offset">
        <div class="form-check">
            <label class="form-check-label">
                <input class="form-check-input" asp-for="IncludeAll" role="button" data-bs-toggle="collapse" data-bs-target=".collapse"
                    aria-expanded="false"/>
                @T["Include all custom user settings."]
            </label>
        </div>
    </div>
</div>

<div class="collapse @(Model.IncludeAll ? String.Empty : "show")">
    <div class="ocat-wrapper">
        <div class="ocat-end-offset">
            <span class="hint">@T["The custom user settings to add as part of the plan."]</span>
        </div>
    </div>
    <div class="ocat-wrapper">
        <div class="ocat-end-offset">
            <ul class="list-group">
                @foreach (var settingsTypeName in Model.AllSettingsTypeNames)
                {
                    var checkd = Model.SettingsTypeNames?.Contains(settingsTypeName);

                    <li class="list-group-item">
                        <div class="form-check">
                            <label class="form-check-label">
                                <input class="form-check-input" type="checkbox" name="@Html.NameFor(m => m.SettingsTypeNames)" value="@settingsTypeName" checked="@checkd">
                                @settingsTypeName
                            </label>
                        </div>
                    </li>
                }
            </ul>
        </div>
    </div>
</div>
