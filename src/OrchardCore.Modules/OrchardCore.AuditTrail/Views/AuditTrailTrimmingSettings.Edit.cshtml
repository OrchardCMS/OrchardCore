@model AuditTrailTrimmingSettingsViewModel

<section>
    <div class="ocat-wrapper" asp-validation-class-for="Disabled">
        <div class="ocat-end-offset">
            <div class="form-check">
                <input type="checkbox" class="form-check-input" asp-for="Disabled" checked="@Model.Disabled" />
                <label class="form-check-label" asp-for="Disabled">@T["Disable trimming task"]</label>
                <span class="hint dashed">@T["Whether the trimming task is disabled."]</span>
            </div>
        </div>
    </div>

    <div class="ocat-wrapper" asp-validation-class-for="RetentionDays">
        <label asp-for="RetentionDays" class="ocat-label">@T["Retention period"]</label>
        <div class="ocat-end">
            <input asp-for="RetentionDays" type="number" class="form-control" />
            <span class="hint">@T["The number of days an event is retained."]</span>
        </div>
    </div>

    <div class="ocat-wrapper" asp-validation-class-for="LastRunUtc">
        <label asp-for="LastRunUtc" class="ocat-label">@T["Last run"]</label>
        <div class="ocat-end">
            <div class="form-control">@(Model.LastRunUtc.HasValue ? await DisplayAsync(await New.DateTime(Utc: Model.LastRunUtc.Value, Format: "g")) : T["Never"])</div>
            <span class="hint">@T["The last time the trimming task was run."]</span>
        </div>
    </div>
</section>
