@using Microsoft.Extensions.Options
@using OrchardCore.Media
@inject IOptions<MediaOptions> MediaOptions
@{
    var jsLocalizations = Orchard.GetJSLocalizations("media-app");
    var translationsJson = System.Text.Json.JsonSerializer.Serialize(jsLocalizations);
}

<div class="modal fade" id="mediaModalMarkdown">
    <div class="modal-dialog file-modal" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">@T["Select Media"]</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div data-media-picker-container="mediaModalMarkdown"
                     data-translations="@translationsJson"
                     data-base-path="@Url.Content("~/")"
                     data-upload-files-url="@Url.Content("~/api/media/Upload")"
                     data-allowed-extensions="@string.Join(",", MediaOptions.Value.AllowedFileExtensions)">
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-primary" id="mediaMarkdownSelectButton">@T["OK"]</button>
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">@T["Cancel"]</button>
            </div>
        </div>
    </div>
</div>

<style asp-name="media" at="Head"></style>
<script asp-name="media" at="Foot"></script>
