@model OrchardCore.Markdown.ViewModels.EditMarkdownFieldViewModel
@using OrchardCore.ContentFields
@using OrchardCore.ContentLocalization
@using OrchardCore.ContentManagement.Metadata.Models
@using OrchardCore.Markdown.Settings
@using OrchardCore.Mvc.Utilities
@using OrchardCore.Localization.Data
@inject IDataLocalizer D
@{
    var settings = Model.PartFieldDefinition.GetSettings<MarkdownFieldSettings>();
    var wysiwygSettings = Model.PartFieldDefinition.GetSettings<MarkdownFieldWysiwygEditorSettings>();
    var culture = await Orchard.GetContentCultureAsync(Model.Field.ContentItem);
    string localizedFieldName = D[Model.PartFieldDefinition.DisplayName(), DataLocalizationContext.ContentField(Model.PartFieldDefinition.PartDefinition.Name)];
}

<style asp-name="codemirror"></style>
<style asp-name="easymde"></style>

<div class="@($"ocat-wrapper field-wrapper field-wrapper-{Model.PartFieldDefinition.PartDefinition.Name.HtmlClassify()}-{Model.PartFieldDefinition.Name.HtmlClassify()}" + (Model.PartFieldDefinition.IsNamedPart() ? $" field-wrapper-{Model.PartFieldDefinition.ContentTypePartDefinition.Name.HtmlClassify()}-{Model.PartFieldDefinition.Name.HtmlClassify()}" : string.Empty))" id="@Html.IdFor(x => x.Markdown)_FieldWrapper">
    @await DisplayAsync(await New.ShortcodeModal())
    <label asp-for="Markdown" class="ocat-label">@localizedFieldName</label>
    <div class="ocat-end">
        <textarea asp-for="Markdown" rows="5" class="form-control content-preview-text"></textarea>
        @if (!string.IsNullOrEmpty(settings.Hint))
        {
            <span class="hint">@settings.Hint</span>
        }
    </div>
</div>

<script at="Foot" depends-on="easymde-mediatoolbar">
    function onDocumentReady(callback) {
        if (document.readyState !== 'loading') {
            callback();
        } else {
            document.addEventListener('DOMContentLoaded', callback);
        }
    }

    onDocumentReady(function () {
        var markdownElement = document.getElementById('@Html.IdFor(m => m.Markdown)');
        var isRtl = '@(culture.IsRightToLeft() ? "true" : "false")';

        // When field is rendered by a flow part only the elements scripts are rendered, so the html element will not exist.
        if (markdownElement) {
@if (!string.IsNullOrWhiteSpace(wysiwygSettings.Options))
{
    <text>
            var customOptions = @Html.Raw(wysiwygSettings.Options);
            if (customOptions.toolbar) {
                // Map custom button names to their full definitions from mdeToolbar.
                var mdeToolbarMap = {};
                mdeToolbar.forEach(function (btn) {
                    if (btn.name) {
                        mdeToolbarMap[btn.name] = btn;
                    }
                });
                customOptions.toolbar = customOptions.toolbar.map(function (item) {
                    if (typeof item === 'string') {
                        return mdeToolbarMap[item] || item;
                    }
                    return item;
                });
            } else {
                customOptions.toolbar = mdeToolbar;
            }
            customOptions.element = markdownElement;
            customOptions.forceSync = true;
            customOptions.autoDownloadFontAwesome = false;
            var mde = new EasyMDE(customOptions);
    </text>
}
else
{
    <text>
            var mde = new EasyMDE({
                element: markdownElement,
                forceSync: true,
                toolbar: mdeToolbar,
                autoDownloadFontAwesome: false
            });
    </text>
}
            initializeMdeShortcodeWrapper(mde);

            mde.codemirror.on('change', function () {
                document.dispatchEvent(new CustomEvent('contentpreview:render'));
            });

            if (isRtl === 'true')
            {
                document.querySelector('.editor-toolbar').setAttribute('style', 'direction:rtl;text-align:right');
                document.querySelector('.CodeMirror').setAttribute('style', 'text-align:right');
            }
        }
    });
</script>
