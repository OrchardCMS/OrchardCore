@using OrchardCore
@model OrchardCore.Widgets.Settings.WidgetsListPartSettingsViewModel

<div class="@Orchard.GetWrapperClasses()" asp-validation-class-for="Zones">
    <label asp-for="Zones" class="@Orchard.GetLabelClasses()">@T["Available widgets zones"]</label>
    <div class="@Orchard.GetEndClasses()">
        <input asp-for="Zones" class="form-control" type="text" />
        <span asp-validation-for="Zones"></span>
        <span class="hint">@T["A comma separated list of values, representing the available zones for widgets."]</span>
    </div>
</div>
