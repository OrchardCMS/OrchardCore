@using OrchardCore
@using OrchardCore.Indexing.ViewModels

@model EditIndexProfileViewModel

<div class="@Orchard.GetWrapperClasses()" asp-validation-class-for="IndexName">
    <label asp-for="IndexName" class="@Orchard.GetLabelClasses()">@T["Index Name"]</label>
    <div class="@Orchard.GetEndClasses()">
    <input asp-for="IndexName" class="form-control" asp-is-disabled="!Model.IsNew" />
    <span asp-validation-for="IndexName" class="text-danger"></span>
    </div>
</div>

<div class="@Orchard.GetWrapperClasses()">
    <label asp-for="Name" class="@Orchard.GetLabelClasses()">@T["Name"]</label>
    <div class="@Orchard.GetEndClasses()">
    <input asp-for="Name" class="form-control" />
    <span asp-validation-for="Name" class="text-danger"></span>
    <span class="hint">@T["A unique name for the index."]</span>
    </div>
</div>

@if (Model.IsNew)
{
    <script asp-src="~/OrchardCore.Indexing/Scripts/technical-name-generator.min.js" debug-src="~/OrchardCore.Indexing/Scripts/technical-name-generator.js" asp-name="technical-name-generator" at="Foot"></script>
    <script at="Foot" depends-on="technical-name-generator">
        TechnicalNameGenerator.initialize('@Html.IdFor(m => m.IndexName)', '@Html.IdFor(m => m.Name)');
    </script>
}
