@using OrchardCore
@model AdminMenuCreateViewModel

<zone Name="Title"><h1>@RenderTitleSegments(T["Create Admin Menu {0}", Model.Name])</h1></zone>

<div asp-validation-summary="ModelOnly"></div>

<form asp-action="Create" method="post" class="no-multisubmit">
    <div class="@Orchard.GetWrapperClasses()" asp-validation-class-for="Name">
        <label asp-for="Name" class="@Orchard.GetLabelClasses()">@T["Name"]</label>
        <div class="@Orchard.GetEndClasses()">
            <input asp-for="Name" class="form-control" autofocus />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>
    </div>

    <div class="@Orchard.GetWrapperClasses()">
        <div class="@Orchard.GetEndClasses(true)">
            <button class="btn btn-success create" type="submit">@T["Create"]</button>
            <a class="btn btn-secondary cancel" role="button" asp-route-action="List">@T["Cancel"]</a>
        </div>
    </div>
</form>
