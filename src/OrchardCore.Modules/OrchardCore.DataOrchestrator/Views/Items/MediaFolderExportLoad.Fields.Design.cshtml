@model EtlActivityViewModel<MediaFolderExportLoad>

<header>
    <h4><i class="fa-solid fa-folder-open"></i> @T["Media Folder Export"]</h4>
</header>
<div>@T["Format:"] @Model.Activity.Format</div>
@if (!string.IsNullOrEmpty(Model.Activity.FileName))
{
    <div>@T["File:"] @Model.Activity.FileName</div>
}
