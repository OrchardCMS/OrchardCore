@model QuerySourceViewModel

<div class="ocat-wrapper" asp-validation-class-for="QueryName">
    <label asp-for="QueryName" class="ocat-label ocat-label-required">@T["Query"]</label>
    <div class="ocat-end">
        <select asp-for="QueryName" asp-items="Model.AvailableQueries" class="form-select" required>
            <option value="">@T["Select a query"]</option>
        </select>
        <span asp-validation-for="QueryName"></span>
        <span class="hint">@T["The query to execute. Queries are managed by the Queries feature."]</span>
    </div>
</div>

<div class="ocat-wrapper" asp-validation-class-for="ParametersJson">
    <label asp-for="ParametersJson" class="ocat-label">@T["Parameters"]</label>
    <div class="ocat-end">
        <textarea asp-for="ParametersJson" rows="4" class="form-control" placeholder='{ "size": 50 }'></textarea>
        <span asp-validation-for="ParametersJson"></span>
        <span class="hint">@T["Optional JSON object of parameters passed to the query."]</span>
    </div>
</div>
