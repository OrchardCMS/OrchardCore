@model EtlActivityViewModel<ExcelSource>

<header>
    <h4><i class="fa-solid fa-file-excel"></i> @T["Excel Workbook"]</h4>
</header>
@if (!string.IsNullOrWhiteSpace(Model.Activity.FilePath))
{
    <div>@T["File:"] @Model.Activity.FilePath</div>
}
@if (!string.IsNullOrWhiteSpace(Model.Activity.WorksheetName))
{
    <div>@T["Sheet:"] @Model.Activity.WorksheetName</div>
}
