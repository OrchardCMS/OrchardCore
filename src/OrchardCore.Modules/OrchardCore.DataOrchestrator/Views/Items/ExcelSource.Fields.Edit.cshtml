@model ExcelSourceViewModel

<div class="ocat-wrapper" asp-validation-class-for="UploadedFile">
    <label asp-for="UploadedFile" class="ocat-label">@T["Upload Excel file"]</label>
    <div class="ocat-end">
        <input asp-for="UploadedFile" type="file" accept=".xlsx" class="form-control" />
        <span asp-validation-for="UploadedFile"></span>
        <span class="hint">@T["Upload an .xlsx workbook. Uploaded files are saved under <code>{0}</code>.", $"{EtlLocalFilePathResolver.DefaultUploadsDirectory}/"]</span>
    </div>
</div>

<div class="ocat-wrapper" asp-validation-class-for="FilePath">
    <label asp-for="FilePath" class="ocat-label">@T["Excel file path"]</label>
    <div class="ocat-end">
        <input asp-for="FilePath" class="form-control" />
        <span asp-validation-for="FilePath"></span>
        <span class="hint">@T[@"Use an .xlsx file path relative to the tenant Data Orchestrator folder. The path is sandboxed under <code>{0}</code> and cannot escape App_Data.", Model.FilesBasePath]</span>
    </div>
</div>

<div class="ocat-wrapper" asp-validation-class-for="WorksheetName">
    <label asp-for="WorksheetName" class="ocat-label">@T["Worksheet name"]</label>
    <div class="ocat-end">
        <input asp-for="WorksheetName" class="form-control" />
        <span asp-validation-for="WorksheetName"></span>
        <span class="hint">@T["Leave empty to read the first worksheet."]</span>
    </div>
</div>

<div class="ocat-wrapper" asp-validation-class-for="HasHeaderRow">
    <div class="ocat-end-offset">
        <div class="form-check">
            <input asp-for="HasHeaderRow" class="form-check-input" />
            <label asp-for="HasHeaderRow" class="form-check-label">@T["First row contains column headers"]</label>
        </div>
        <span asp-validation-for="HasHeaderRow"></span>
    </div>
</div>
