@inject IDeploymentManager DeploymentManager
@* Only insert modal once per page *@
@if (!Context.Items.ContainsKey("ExportContentToDeploymentTarget_Modal__ActionDeploymentTarget"))
{
    Context.Items["ExportContentToDeploymentTarget_Modal__ActionDeploymentTarget"] = new object(); 

    <zone name="Footer">
        <div class="modal fade" id="modalExportContentToDeploymentTargetActionTarget" tabindex="-1" role="dialog" aria-labelledby="deployment-targets-title" aria-hidden="true">
            <div class="modal-dialog modal-lg" role="document">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title" id="deployment-targets-title">@T["Available Targets"]</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <div class="row row-cols-1 row-cols-md-2 g-2">
                            @foreach (var target in await DeploymentManager.GetDeploymentTargetsAsync())
                            {
                                var routeWithId = new RouteValueDictionary(target.Route);
                                routeWithId["id"] = Site.GetOrCreate<ExportContentToDeploymentTargetSettings>().ExportContentToDeploymentTargetPlanId;
                                routeWithId["returnUrl"] = FullRequestPath;

                                <div class="col">
                                    <div class="card h-100 mb-3">
                                        <div class="card-body">
                                            <h4 class="card-title">@target.Name</h4>
                                            <p>@target.Description</p>
                                        </div>
                                        <div class="card-footer text-muted text-sm-end">
                                            <button type="button" class="export-to-deployment-target text-white btn btn-primary btn-sm" data-bs-dismiss="modal" data-target-url="@Url.RouteUrl(routeWithId)">@T["Select"]</button>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">@T["Cancel"]</button>
                    </div>
                </div>
            </div>
        </div>
    </zone>

    <script asp-src="~/OrchardCore.Contents/Scripts/deployment-modals/export-to-deployment-target-action.min.js" debug-src="~/OrchardCore.Contents/Scripts/deployment-modals/export-to-deployment-target-action.js" at="Foot" type="module"></script>
}
