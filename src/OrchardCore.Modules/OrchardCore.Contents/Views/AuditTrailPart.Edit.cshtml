@model AuditTrailPartViewModel
@using OrchardCore.Contents.AuditTrail.ViewModels
@using OrchardCore

<div class="ocat-wrapper">
    <label asp-for="Comment" class="ocat-label">@T["Comment"]</label>
    <div class="ocat-end">
        <textarea asp-for="Comment" rows="5" class="form-control"></textarea>
        <span class="hint">@T["Optionally provide a comment about this change for the audit trail."]</span>
    </div>
</div>
