<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <RootNamespace>OrchardCore.Search.OpenSearch</RootNamespace>
    <!-- NuGet properties-->
    <Title>OrchardCore OpenSearch Search Abstractions</Title>
    <Description>
      $(OCCMSDescription)

      Abstractions for OpenSearch Search.</Description>
    <PackageTags>$(PackageTags) OrchardCoreCMS Abstractions</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="OpenSearch.Client" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\OrchardCore.Queries.Abstractions\OrchardCore.Queries.Abstractions.csproj" />
  </ItemGroup>

</Project>
