{
  "name": "EsModuleTests",
  "displayName": "EsModuleTests",
  "description": "Testing the ES-module-converted field/part editors (TextField-IconPicker, HtmlField-Wysiwyg/Trumbowyg, HtmlBodyPart-Wysiwyg/Trumbowyg) on both a normal full page load and when injected via the FlowPart 'Add Widget' AJAX flow.",
  "author": "The Orchard Core Team",
  "website": "https://orchardcore.net",
  "version": "1.0.0",
  "issetuprecipe": true,
  "categories": [ "tests" ],
  "tags": [ "tests" ],

  "variables": {
    "seededPageId": "[js:uuid()]",
    "seededWidgetId": "[js:uuid()]"
  },

  "steps": [
    {
      "name": "feature",
      "enable": [
        "OrchardCore.HomeRoute",
        "OrchardCore.Admin",
        "OrchardCore.Navigation",
        "OrchardCore.Recipes",
        "OrchardCore.Resources",
        "OrchardCore.Roles",
        "OrchardCore.Security",
        "OrchardCore.Settings",
        "OrchardCore.Themes",
        "OrchardCore.Users",

        "OrchardCore.ContentFields",
        "OrchardCore.Contents",
        "OrchardCore.ContentTypes",
        "OrchardCore.Flows",
        "OrchardCore.Html",
        "OrchardCore.Title",
        "OrchardCore.Widgets",

        "TheAdmin",
        "SafeMode"
      ]
    },
    {
      "name": "themes",
      "admin": "TheAdmin",
      "site": "TheAdmin"
    },
    {
      "name": "ContentDefinition",
      "ContentTypes": [
        {
          "Name": "EsModuleTestPage",
          "DisplayName": "Es Module Test Page",
          "Settings": {
            "ContentTypeSettings": {
              "Creatable": true,
              "Draftable": true,
              "Versionable": true,
              "Listable": true,
              "Securable": true
            }
          },
          "ContentTypePartDefinitionRecords": [
            {
              "PartName": "TitlePart",
              "Name": "TitlePart",
              "Settings": {
                "ContentTypePartSettings": {
                  "Position": "0"
                }
              }
            },
            {
              "PartName": "FlowPart",
              "Name": "FlowPart",
              "Settings": {
                "ContentTypePartSettings": {
                  "Position": "1"
                }
              }
            }
          ]
        },
        {
          "Name": "EsModuleTestFieldsWidget",
          "DisplayName": "Es Module Test Fields Widget",
          "Settings": {
            "ContentTypeSettings": {
              "Draftable": true,
              "Versionable": true,
              "Securable": true,
              "Stereotype": "Widget"
            }
          },
          "ContentTypePartDefinitionRecords": [
            {
              "PartName": "TitlePart",
              "Name": "TitlePart",
              "Settings": {
                "ContentTypePartSettings": {
                  "Position": "0"
                }
              }
            },
            {
              "PartName": "EsModuleTestFieldsWidget",
              "Name": "EsModuleTestFieldsWidget",
              "Settings": {
                "ContentTypePartSettings": {
                  "Position": "1"
                }
              }
            }
          ]
        },
        {
          "Name": "EsModuleTestHtmlBodyTrumbowyg",
          "DisplayName": "Es Module Test HtmlBody Trumbowyg",
          "Settings": {
            "ContentTypeSettings": {
              "Draftable": true,
              "Versionable": true,
              "Securable": true,
              "Stereotype": "Widget"
            }
          },
          "ContentTypePartDefinitionRecords": [
            {
              "PartName": "TitlePart",
              "Name": "TitlePart",
              "Settings": {
                "ContentTypePartSettings": {
                  "Position": "0"
                }
              }
            },
            {
              "PartName": "HtmlBodyPart",
              "Name": "HtmlBodyPart",
              "Settings": {
                "ContentTypePartSettings": {
                  "Editor": "Trumbowyg",
                  "Position": "1"
                }
              }
            }
          ]
        },
        {
          "Name": "EsModuleTestHtmlBodyWysiwyg",
          "DisplayName": "Es Module Test HtmlBody Wysiwyg",
          "Settings": {
            "ContentTypeSettings": {
              "Draftable": true,
              "Versionable": true,
              "Securable": true,
              "Stereotype": "Widget"
            }
          },
          "ContentTypePartDefinitionRecords": [
            {
              "PartName": "TitlePart",
              "Name": "TitlePart",
              "Settings": {
                "ContentTypePartSettings": {
                  "Position": "0"
                }
              }
            },
            {
              "PartName": "HtmlBodyPart",
              "Name": "HtmlBodyPart",
              "Settings": {
                "ContentTypePartSettings": {
                  "Editor": "Wysiwyg",
                  "Position": "1"
                }
              }
            }
          ]
        }
      ],
      "ContentParts": [
        {
          "Name": "EsModuleTestFieldsWidget",
          "Settings": {},
          "ContentPartFieldDefinitionRecords": [
            {
              "FieldName": "TextField",
              "Name": "IconField",
              "Settings": {
                "ContentPartFieldSettings": {
                  "DisplayName": "Icon",
                  "Editor": "IconPicker",
                  "Position": "0"
                }
              }
            },
            {
              "FieldName": "HtmlField",
              "Name": "WysiwygField",
              "Settings": {
                "ContentPartFieldSettings": {
                  "DisplayName": "Wysiwyg Content",
                  "Editor": "Wysiwyg",
                  "Position": "1"
                }
              }
            },
            {
              "FieldName": "HtmlField",
              "Name": "TrumbowygField",
              "Settings": {
                "ContentPartFieldSettings": {
                  "DisplayName": "Trumbowyg Content",
                  "Editor": "Trumbowyg",
                  "Position": "2"
                }
              }
            }
          ]
        }
      ]
    },
    {
      "name": "content",
      "Data": [
        {
          "ContentItemId": "[js: variables('seededPageId')]",
          "ContentType": "EsModuleTestPage",
          "DisplayText": "ES Module Test Page",
          "Latest": true,
          "Published": true,
          "Owner": "[js: parameters('AdminUserId')]",
          "Author": "[js: parameters('AdminUsername')]",
          "TitlePart": {
            "Title": "ES Module Test Page"
          },
          "FlowPart": {
            "Widgets": [
              {
                "ContentItemId": "[js: variables('seededWidgetId')]",
                "ContentType": "EsModuleTestFieldsWidget",
                "DisplayText": "Seeded Fields Widget",
                "Latest": true,
                "Published": true,
                "Owner": "[js: parameters('AdminUserId')]",
                "Author": "[js: parameters('AdminUsername')]",
                "TitlePart": {
                  "Title": "Seeded Fields Widget"
                },
                "EsModuleTestFieldsWidget": {
                  "IconField": {
                    "Text": "fa-solid fa-car"
                  },
                  "WysiwygField": {
                    "Html": "<p>Seeded wysiwyg content.</p>"
                  },
                  "TrumbowygField": {
                    "Html": "<p>Seeded trumbowyg content.</p>"
                  }
                }
              }
            ]
          }
        }
      ]
    }
  ]
}
