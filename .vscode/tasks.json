{
  "version": "2.0.0",
  "inputs": [
    {
      "id": "targetFramework",
      "type": "pickString",
      "description": "Select target framework",
      "options": [
        "net10.0"
      ],
      "default": "net10.0"
    }
  ],
  "tasks": [
    {
      "label": "dotnet watch",
      "type": "process",
      "command": "dotnet",
      "args": [
        "watch",
        "--project",
        "${workspaceFolder}/src/OrchardCore.Cms.Web/OrchardCore.Cms.Web.csproj",
        "-f",
        "${input:targetFramework}"
      ],
      "options": {
        "env": {
          "ASPNETCORE_ENVIRONMENT": "Development"
        }
      },
      "isBackground": true,
      "problemMatcher": {
        "base": "$msCompile",
        "background": {
          "activeOnStart": true,
          "beginsPattern": "dotnet watch",
          "endsPattern": "\\bNow listening on:\\s+(https?://\\S+)"
        }
      }
    },
    {
      "label": "dotnet build (debug)",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/src/OrchardCore.Cms.Web",
        "-c",
        "Debug",
        "-f",
        "${input:targetFramework}"
      ],
      "problemMatcher": "$msCompile"
    },
    {
      "label": "dotnet build (release)",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/src/OrchardCore.Cms.Web",
        "-c",
        "Release",
        "-f",
        "${input:targetFramework}"
      ],
      "problemMatcher": "$msCompile"
    },
    {
      "label": "dotnet run",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "run",
        "--project",
        "${workspaceFolder}/src/OrchardCore.Cms.Web/OrchardCore.Cms.Web.csproj",
        "-f",
        "${input:targetFramework}"
      ]
    },
    {
      "label": "dotnet restore",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "restore"
      ]
    },
    {
      "label": "dotnet restore force",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "restore",
        "--no-cache"
      ]
    },
    {
      "label": "dotnet clean (debug)",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "clean",
        "--configuration",
        "Debug"
      ]
    },
    {
      "label": "dotnet clean (release)",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "clean",
        "--configuration",
        "Release"
      ]
    },
    {
      "label": "dotnet rebuild (debug)",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/src/OrchardCore.Cms.Web",
        "--no-incremental",
        "-c",
        "Debug",
        "-f",
        "${input:targetFramework}"
      ],
      "problemMatcher": "$msCompile"
    },
    {
      "label": "dotnet rebuild (release)",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/src/OrchardCore.Cms.Web",
        "--no-incremental",
        "-c",
        "Release",
        "-f",
        "${input:targetFramework}"
      ],
      "problemMatcher": "$msCompile"
    },
    {
      "label": "cleanup publish folder",
      "type": "shell",
      "command": "rm",
      "windows": {
        "command": "Remove-Item",
        "args": [
          "${workspaceFolder}\\.build\\release\\*",
          "-recurse"
        ]
      },
      "args": [
        "-rfv",
        "${workspaceFolder}/.build/release/*"
      ]
    },
    {
      "label": "dotnet publish (self-contained) - release",
      "type": "shell",
      "command": "dotnet",
      "windows": {
        "command": "dotnet",
        "args": [
          "publish",
          "${workspaceFolder}\\src\\OrchardCore.Cms.Web",
          "--configuration",
          "release",
          "--runtime",
          "win-x64",
          "--self-contained",
          "--framework",
          "${input:targetFramework}",
          "--output",
          ".\\.build\\release"
        ]
      },
      "args": [
        "publish",
        "${workspaceFolder}/src/OrchardCore.Cms.Web",
        "--configuration",
        "release",
        "--runtime",
        "linux-x64",
        "--self-contained",
        "--framework",
        "${input:targetFramework}",
        "--output",
        "./.build/release"
      ],
      "problemMatcher": "$msCompile"
    },
    {
      "label": "dotnet publish (framework dependent) - release",
      "type": "shell",
      "command": "dotnet",
      "windows": {
        "command": "dotnet",
        "args": [
          "publish",
          "${workspaceFolder}\\src\\OrchardCore.Cms.Web",
          "--configuration",
          "release",
          "--runtime",
          "win-x64",
          "--self-contained",
          "false",
          "--framework",
          "${input:targetFramework}",
          "--output",
          ".\\.build\\release"
        ]
      },
      "args": [
        "publish",
        "${workspaceFolder}/src/OrchardCore.Cms.Web",
        "--configuration",
        "release",
        "--runtime",
        "linux-x64",
        "--self-contained",
        "false",
        "--framework",
        "${input:targetFramework}",
        "--output",
        "./.build/release"
      ],
      "problemMatcher": "$msCompile"
    },
    {
      "label": "tasks: dotnet publish release (self-contained)",
      "dependsOn": [
        "cleanup publish folder",
        "dotnet publish (self-contained) - release"
      ]
    },
    {
      "label": "tasks: dotnet publish release (framework dependent)",
      "dependsOn": [
        "cleanup publish folder",
        "dotnet publish (framework dependent) - release"
      ]
    },
    {
      "label": "yarn build - rebuild all assets",
      "type": "shell",
      "command": "yarn",
      "args": [
        "build"
      ],
      "problemMatcher": []
    }
  ]
}
